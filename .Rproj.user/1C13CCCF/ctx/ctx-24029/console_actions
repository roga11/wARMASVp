        "for (dgp in dgp_tab3) {",
        "+ ",
        "  true_theta <- c(dgp$phi, dgp$sigy, dgp$sigv, dgp$nu)",
        "+ ",
        "  n_par <- 4",
        "+ ",
        "  for (Tsize in Tsize_ls) {",
        "+ ",
        "    cat(sprintf(\"  Student-t nu=%d, %s pers., T=%d\\n\", dgp$nu, dgp$persist, Tsize))",
        "+ ",
        "    estimsB <- matrix(NA, B, n_par)",
        "+ ",
        "    xb <- 1",
        "+ ",
        "    while (xb <= B) {",
        "+ ",
        "      y <- sim_sv_t(Tsize, phi = dgp$phi, sigy = dgp$sigy,",
        "+ ",
        "                    sigv = dgp$sigv, nu = dgp$nu, burnin = burnin)",
        "+ ",
        "      mdl <- tryCatch(",
        "+ ",
        "        svp(y, p = 1, J = J, leverage = FALSE, errorType = \"Student-t\",",
