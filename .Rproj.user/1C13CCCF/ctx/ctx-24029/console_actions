        "dgp_tab3 <- list(",
        "+ ",
        "  list(phi = 0.90, sigy = 1.0, sigv = 1.5, nu = 5, persist = \"Medium\"),",
        "+ ",
        "  list(phi = 0.95, sigy = 1.0, sigv = 1.5, nu = 5, persist = \"High\"),",
