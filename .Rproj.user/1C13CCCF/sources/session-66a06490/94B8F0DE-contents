  }
  for (int i=1; i<n; i ++){
    u.row(i) = zeta.row(i) * exp(h.row(i) / 2)*sy;
  }
  u = u.rows(burnin,n-1);
  
  h = h.rows(burnin,n-1);
  zeta = zeta.rows(burnin,n-1);
  veta = veta.rows(burnin,n-1);
  
  List out;
  out["y"] = u;
  out["h"] = h;
  out["zeta"] = zeta;
  out["veta"] = veta;
