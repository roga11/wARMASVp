// [[Rcpp::export]]
arma::mat statPhi_cpp(arma::mat phiB) {
  Rcpp::Environment gsignal("package:gsignal");
  Rcpp::Function polyR = gsignal["poly"];
  double Del = 1 - 0.0001;
  arma::vec pl = arma::join_cols(arma::vec{1}, -phiB);
  arma::cx_vec r = roots(pl);
  arma::uvec indices = find(abs(r) >= 1);
  r.elem(indices) = sign(r.elem(indices)) * Del;
  arma::vec polyc = real(as<arma::vec>(polyR(r)));
  phiB = -polyc.subvec(1, polyc.n_elem - 1);
  return(phiB);
}

// [[Rcpp::export]]
double kendall_corr(arma::vec x, arma::vec y) {
  int n = x.n_elem;
  if (n != y.n_elem) {
    Rcpp::stop("Input vectors must have the same length.");
  }
  
  int concordant = 0;
  int discordant = 0;
  int tied_pairs = 0;
  
  for (int i = 0; i < (n - 1); ++i) {
    for (int j = i + 1; j < n; ++j) {
      double diff_x = x(i) - x(j);
      double diff_y = y(i) - y(j);
      
      if (diff_x == 0 && diff_y == 0) {
        tied_pairs++;
      } else {
        concordant += (diff_x * diff_y > 0);
        discordant += (diff_x * diff_y < 0);
      }
    }
  }
  
  // Handle tied pairs
  double adj_concordant = concordant + 0.5 * tied_pairs;
  double adj_discordant = discordant + 0.5 * tied_pairs;
  
  // Handle the case when adj_concordant + adj_discordant is zero
  if (adj_concordant + adj_discordant == 0) {
    return 0.0;
  }
  
  double tau = (adj_concordant - adj_discordant) / sqrt((adj_concordant + adj_discordant) * n * (n - 1) / 2);
  return tau;
}


// [[Rcpp::export]]
arma::mat acov_g(arma::mat y, int k) {
  // ----------------------------------------------------------------------- #
  // Description: 
  //   
  //
  // Input:
  //   
  //
  // Output: 
  //   
  // ----------------------------------------------------------------------- #
  int Tsize = y.n_rows;// Get the number of rows in y
  // Calculate the autocovariance matrix gamma
  arma::mat gamma = (1.0 / (Tsize - k)) * trans(y.rows(k, Tsize - 1)) * y.rows(0, Tsize - k - 1);
  return gamma;
}

// [[Rcpp::export]]
arma::cx_vec signR_cpp(arma::cx_vec vec) {
  // ----------------------------------------------------------------------- #
  // Description: 
  //   
  //
  // Input:
  //   
  //
  // Output: 
  //   
  // ----------------------------------------------------------------------- #
  // Check if the vector is complex
  if (std::is_same<arma::cx_vec::elem_type, std::complex<double>>::value) {
    // Return the vector divided by its absolute values
    return vec / arma::abs(vec);
  } else {
    // Return the sign of the vector
    return arma::sign(vec);
  }
}

// [[Rcpp::export]]
arma::mat sim_svp_leverage_norm_cpp_old(arma::vec beta, int p, int  N, int burnin){
  // ----------------------------------------------------------------------- //
  // Description:
  //  Simulate stochastic volatility process with normally 
  //  distributed errors and leverage.
  
  // INPUTS:
  //  beta    - [(p+3) x 1] vector with: phi, sy (standard dev of y), sv (std. dev. of v), 
  //            rho0 (leverage parameter)
  //  N       - length of series
  // burnin  - number of initial observations to discard.
  
  //  OUTPUTS:
  //  u     - NxK matrix with SV process in each column
  
  // NOTE: 
  //  ----------------------------------------------------------------------- //
  int n = burnin + N;
  
  arma::vec phi = beta.subvec(0,p-1);
  double sy = beta(p);
  double sv = beta(p+1);
  double rho0 = beta(p+2);
  
  arma::mat h(n, 1, arma::fill::zeros);
  arma::mat u(n, 1, arma::fill::zeros);
  
  arma::mat  veta = rnorm(n + 1);
  arma::mat  eps = rnorm(n + 1);
  
  arma::mat epst = rho0*veta + sqrt(1-pow(rho0,2))*eps;
  
  arma::mat v(p,1, arma::fill::zeros);
  h.rows(0,p-1) = v.rows(0,p-1); ///(1-phi)
  u.row(0) = epst.row(0)*exp(h.row(0) / 2)*sy;
  for (int i=p; i<n; i ++){
    h.row(i) = v(0) + trans(phi)*flipud(h.rows(i-p,i-1)) + veta.row(i)*sv;
  }
  for (int i=1; i<n; i ++){
    u.row(i) = epst.row(i-1) * exp(h.row(i) / 2)*sy;
  }
  u = u.rows(burnin,n-1);
  
  return(u);
}


