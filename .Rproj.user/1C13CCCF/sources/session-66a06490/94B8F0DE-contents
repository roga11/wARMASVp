// [[Rcpp::export]]
List svpCpp(arma::vec u, int p, int J, bool trunc_lev, double del, int rho_type = 1, bool wDecay = FALSE) {
  Rcpp::Environment gsignal("package:gsignal");
  Rcpp::Function polyR = gsignal["poly"];
  
  // ----- get y*
  int N = u.n_elem;
  arma::vec u2 = square(u) + del;
  double mu = mean(log(u2));
  arma::mat y = log(u2) - mu;
  
  // ----- compute sigma_y
  double s_yh = sqrt(exp(mu + 1.2704));
  
  // ----- compute phi
  arma::mat xMM1(J * p, p, arma::fill::zeros);
  arma::mat yVM1(J * p, 1, arma::fill::zeros);
  arma::mat wDec(J * p, 1, arma::fill::zeros);
  for (int jj = 0; jj < J; ++jj) {
    arma::mat xM(p, p, arma::fill::zeros);
    arma::mat yV(p, 1, arma::fill::zeros);
    for (int i = 0; i < p; ++i) {
      arma::rowvec xMv(p, arma::fill::zeros);
      for (int j = 0; j < p; ++j) {
        int ki = i + p - 1 + jj;
        int k = ki - j + 1;
        xMv(j) = acov_g(y, k)(0, 0);
      }
      xM.row(i) = xMv;
      yV(i) = acov_g(y, p + i + jj + 1)(0, 0);
    }
    xMM1.rows(jj * p, (jj + 1) * p - 1) = xM;
    yVM1.rows(jj * p, (jj + 1) * p - 1) = yV;
    wDec.rows(jj * p, (jj + 1) * p - 1).fill((2.0 / J) * (1.0 - (double(jj + 1) / (J + 1))));
  }
  arma::mat phiB = pinv(trans(xMM1) * xMM1) * trans(xMM1) * yVM1;
  //Use decaying weights
  if (wDecay==TRUE){
    arma::mat rowones(1,p,arma::fill::ones);
    arma::mat wolsDec = arma::sqrt(wDec);
    arma::mat wolsDecX = arma::sqrt(wDec)*rowones;
    phiB = pinv(trans(wolsDecX%xMM1) * (wolsDecX%xMM1)) * trans(wolsDecX%xMM1) * (wolsDec%yVM1);
  }
  // Check stationarity 
  double Del = 1 - 0.0001;
  arma::vec pl = arma::join_cols(arma::vec{1}, -phiB);
  arma::cx_vec r = roots(pl);
  arma::uvec indices = find(abs(r) >= 1);
  r.elem(indices) = sign(r.elem(indices)) * Del;
  arma::vec polyc = real(as<arma::vec>(polyR(r)));
  phiB = -polyc.subvec(1, polyc.n_elem - 1);
  
  // ----- compute sigma_v
  arma::vec phigB = trans(phiB) * xMM1.submat(0, xMM1.n_cols - 1, p - 1, xMM1.n_cols - 1);
  double s_vh2_ols;
  if (p == 1) {
    s_vh2_ols = (1 - pow(phiB(0), 2)) * (as_scalar(arma::var(y)) - pow(arma::datum::pi, 2) / 2);
  } else {
    s_vh2_ols = as_scalar(arma::var(y)) - pow(arma::datum::pi, 2) / 2 - phigB(0);
  }
  // var(log(u^2+del_y)) del_y = 0.0000001
  double s_vh_ols;
  if (s_vh2_ols<0){
    s_vh_ols = 0.01;
  }else{
    s_vh_ols = sqrt(s_vh2_ols);
  }
  
  // ----- compute rho (delta in paper)
  arma::vec yabs = abs(u);
  double muu = sum(u.subvec(0, N - 2)) / (N-1);
  double mua = sum(yabs.subvec(1, N - 1)) / (N-1);
  // lambda_y(1) using Kendall correlation
  double EH = 0.0;
  if (rho_type == 2){
    double EH_kentmp = kendall_corr(yabs.subvec(1, N - 1)-mua, u.subvec(0, N - 2)-muu);
    arma::vec VYA = (1.0 / (N - 2)) * trans(yabs.subvec(1, N - 1)-mua) * (yabs.subvec(1, N - 1)-mua);
    arma::vec VYN = (1.0 / (N - 2)) * trans(u.subvec(0, N - 2)-muu) * (u.subvec(0, N - 2)-muu);
    EH = EH_kentmp*sqrt(VYA(0)*VYN(0));// + mua*muu;  
  }else if (rho_type == 1){
    // lambda_y(1) using Pearson correlation
    EH = ((1.0 / (N - 2))*as_scalar(trans(yabs.subvec(1, N - 1)-mua)*(u.subvec(0, N - 2)-muu)));//+ mua*muu;  
  }
  // gamma tilde
  double gammatilde;
  if (p == 1) {
    gammatilde = pow(s_vh_ols, 2) / (1 - phiB(0));
  } else if (p == 2) {
    gammatilde = pow(s_vh_ols, 2) / ((1 - phiB(0) - phiB(1)) * (1 + phiB(1)));
  } else if (p == 3) {
    gammatilde = ((1 - phiB(2)) * pow(s_vh_ols, 2)) / ((1 - phiB(0) - phiB(1) - phiB(2)) * (1 + phiB(0) * phiB(2) + phiB(1) - pow(phiB(2), 2)));
  } else if (p == 4) {
    gammatilde = ((1 - phiB(2) - phiB(0) * phiB(3) - pow(phiB(3), 2)) * pow(s_vh_ols, 2)) / ((1 - phiB(0) - phiB(1) - phiB(2) - phiB(3)) * (1 + phiB(0) * (phiB(2) + phiB(1)) + phiB(3) + 2 * phiB(1) * phiB(3) + pow(phiB(0), 2) * phiB(3) + phiB(1) * pow(phiB(3), 2) - pow(phiB(2), 2) - pow(phiB(3), 2) - pow(phiB(3), 3) - phiB(0) * phiB(2) * phiB(3)));
  } else {
    Rcpp::warning("Order 'p' must be <=4.");
    gammatilde = NAN;
  }
  // compute rho (delta)
  double rho = (sqrt(2 * arma::datum::pi) * EH) / (s_vh_ols * pow(s_yh, 2)) * exp(-0.25 * gammatilde);
  // truncation of rho paramater to be between [-1,1]
  if (trunc_lev) {
      if (rho < -1) {
        rho = -1;
      } else if (rho > 1) {
        rho = 1;
      }
  }
  // ----- Organize output
  List para = List::create(
    Named("mu") = mu,
    Named("phi") = phiB,
    Named("sigv") = s_vh_ols,
    Named("sigy") = s_yh,
    Named("rho") = rho,
    Named("gammatilde") = gammatilde,
    Named("nonstationary_ind") = (indices.n_elem > 0)
  );
  // ----- return output
  return para;
}





// [[Rcpp::export]]
List svpCpp_testdely(arma::vec u, int p, int J, bool trunc_lev, double del, double dely, int rho_type = 1, bool wDecay = FALSE) {
  Rcpp::Environment gsignal("package:gsignal");
  Rcpp::Function polyR = gsignal["poly"];
  
  // ----- get y*
  int N = u.n_elem;
  arma::vec u2 = square(u) + del;
  double mu = mean(log(u2));
  arma::mat y = log(u2) - mu;
  
  // ----- compute sigma_y
  double s_yh = sqrt(exp(mu + 1.2704));
  
  // ----- compute phi
  arma::mat xMM1(J * p, p, arma::fill::zeros);
  arma::mat yVM1(J * p, 1, arma::fill::zeros);
  arma::mat wDec(J * p, 1, arma::fill::zeros);
  for (int jj = 0; jj < J; ++jj) {
    arma::mat xM(p, p, arma::fill::zeros);
    arma::mat yV(p, 1, arma::fill::zeros);
    for (int i = 0; i < p; ++i) {
      arma::rowvec xMv(p, arma::fill::zeros);
      for (int j = 0; j < p; ++j) {
        int ki = i + p - 1 + jj;
        int k = ki - j + 1;
        xMv(j) = acov_g(y, k)(0, 0);
      }
      xM.row(i) = xMv;
      yV(i) = acov_g(y, p + i + jj + 1)(0, 0);
    } 
    xMM1.rows(jj * p, (jj + 1) * p - 1) = xM;
    yVM1.rows(jj * p, (jj + 1) * p - 1) = yV;
    wDec.rows(jj * p, (jj + 1) * p - 1).fill((2.0 / J) * (1.0 - (double(jj + 1) / (J + 1))));
  } 
  arma::mat phiB = pinv(trans(xMM1) * xMM1) * trans(xMM1) * yVM1;
  //Use decaying weights
  if (wDecay==TRUE){
    arma::mat rowones(1,p,arma::fill::ones);
    arma::mat wolsDec = arma::sqrt(wDec);
    arma::mat wolsDecX = arma::sqrt(wDec)*rowones;
    phiB = pinv(trans(wolsDecX%xMM1) * (wolsDecX%xMM1)) * trans(wolsDecX%xMM1) * (wolsDec%yVM1);
  }
  // Check stationarity 
  double Del = 1 - 0.0001;
  arma::vec pl = arma::join_cols(arma::vec{1}, -phiB);
  arma::cx_vec r = roots(pl);
  arma::uvec indices = find(abs(r) >= 1);
  r.elem(indices) = sign(r.elem(indices)) * Del;
  arma::vec polyc = real(as<arma::vec>(polyR(r)));
  phiB = -polyc.subvec(1, polyc.n_elem - 1);
  
  // ----- compute sigma_v
  arma::vec phigB = trans(phiB) * xMM1.submat(0, xMM1.n_cols - 1, p - 1, xMM1.n_cols - 1);
  double s_vh2_ols;
  double varydely = arma::as_scalar(arma::var(log(square(u) + dely)));
  if (p == 1) {
    s_vh2_ols = (1 - pow(phiB(0), 2)) * (varydely - pow(arma::datum::pi, 2) / 2);
  } else {
    s_vh2_ols = varydely - pow(arma::datum::pi, 2) / 2 - phigB(0);
  }
  double s_vh_ols;
  if (s_vh2_ols<0){
    s_vh_ols = 0.01;
  }else{ 
    s_vh_ols = sqrt(s_vh2_ols);
  } 
  
  // ----- compute rho (delta in paper)
  arma::vec yabs = abs(u);
  double muu = sum(u.subvec(0, N - 2)) / (N-1);
  double mua = sum(yabs.subvec(1, N - 1)) / (N-1);
  // lambda_y(1) using Kendall correlation
  double EH = 0.0;
  if (rho_type == 2){
    double EH_kentmp = kendall_corr(yabs.subvec(1, N - 1)-mua, u.subvec(0, N - 2)-muu);
    arma::vec VYA = (1.0 / (N - 2)) * trans(yabs.subvec(1, N - 1)-mua) * (yabs.subvec(1, N - 1)-mua);
    arma::vec VYN = (1.0 / (N - 2)) * trans(u.subvec(0, N - 2)-muu) * (u.subvec(0, N - 2)-muu);
    EH = EH_kentmp*sqrt(VYA(0)*VYN(0));// + mua*muu;  
  }else if (rho_type == 1){
    // lambda_y(1) using Pearson correlation
    EH = ((1.0 / (N - 2))*as_scalar(trans(yabs.subvec(1, N - 1)-mua)*(u.subvec(0, N - 2)-muu)));//+ mua*muu;  
  } 
  // gamma tilde
  double gammatilde;
  if (p == 1) {
    gammatilde = pow(s_vh_ols, 2) / (1 - phiB(0));
  } else if (p == 2) { 
    gammatilde = pow(s_vh_ols, 2) / ((1 - phiB(0) - phiB(1)) * (1 + phiB(1)));
  } else if (p == 3) { 
    gammatilde = ((1 - phiB(2)) * pow(s_vh_ols, 2)) / ((1 - phiB(0) - phiB(1) - phiB(2)) * (1 + phiB(0) * phiB(2) + phiB(1) - pow(phiB(2), 2)));
  } else if (p == 4) { 
    gammatilde = ((1 - phiB(2) - phiB(0) * phiB(3) - pow(phiB(3), 2)) * pow(s_vh_ols, 2)) / ((1 - phiB(0) - phiB(1) - phiB(2) - phiB(3)) * (1 + phiB(0) * (phiB(2) + phiB(1)) + phiB(3) + 2 * phiB(1) * phiB(3) + pow(phiB(0), 2) * phiB(3) + phiB(1) * pow(phiB(3), 2) - pow(phiB(2), 2) - pow(phiB(3), 2) - pow(phiB(3), 3) - phiB(0) * phiB(2) * phiB(3)));
  } else { 
    Rcpp::warning("Order 'p' must be <=4.");
    gammatilde = NAN;
  } 
  // compute rho (delta)
  double rho = (sqrt(2 * arma::datum::pi) * EH) / (s_vh_ols * pow(s_yh, 2)) * exp(-0.25 * gammatilde);
  // truncation of rho paramater to be between [-1,1]
  if (trunc_lev) {
    if (rho < -1) { 
      rho = -1;
    } else if (rho > 1) {
      rho = 1;
    }
  }
  // ----- Organize output
  List para = List::create(
    Named("mu") = mu,
    Named("phi") = phiB,
    Named("sigv") = s_vh_ols,
    Named("sigy") = s_yh,
    Named("rho") = rho,
    Named("gammatilde") = gammatilde,
    Named("nonstationary_ind") = (indices.n_elem > 0)
  ); 
  // ----- return output
  return para;
} 




// [[Rcpp::export]]
List svpCpp_nolev(arma::vec u, int p, int J, double del, bool wDecay = FALSE) {
  Rcpp::Environment gsignal("package:gsignal");
  Rcpp::Function polyR = gsignal["poly"];
  
  // ----- get y*
  //int N = u.n_elem;
  arma::vec u2 = square(u) + del;
  double mu = mean(log(u2));
  arma::mat y = log(u2) - mu;
  
  // ----- compute sigma_y
  double s_yh = sqrt(exp(mu + 1.2704));
  
  // ----- compute phi
  arma::mat xMM1(J * p, p, arma::fill::zeros);
  arma::mat yVM1(J * p, 1, arma::fill::zeros);
  arma::mat wDec(J * p, 1, arma::fill::zeros);
  for (int jj = 0; jj < J; ++jj) {
    arma::mat xM(p, p, arma::fill::zeros);
    arma::mat yV(p, 1, arma::fill::zeros);
    for (int i = 0; i < p; ++i) {
      arma::rowvec xMv(p, arma::fill::zeros);
      for (int j = 0; j < p; ++j) {
        int ki = i + p - 1 + jj;
        int k = ki - j + 1;
        xMv(j) = acov_g(y, k)(0, 0);
      }
      xM.row(i) = xMv;
      yV(i) = acov_g(y, p + i + jj + 1)(0, 0);
    }
    xMM1.rows(jj * p, (jj + 1) * p - 1) = xM;
    yVM1.rows(jj * p, (jj + 1) * p - 1) = yV;
    wDec.rows(jj * p, (jj + 1) * p - 1).fill((2.0 / J) * (1.0 - (double(jj + 1) / (J + 1))));
  }
  arma::mat phiB = pinv(trans(xMM1) * xMM1) * trans(xMM1) * yVM1;
  //Use decaying weights
  if (wDecay==TRUE){
    arma::mat rowones(1,p,arma::fill::ones);
    arma::mat wolsDec = arma::sqrt(wDec);
    arma::mat wolsDecX = arma::sqrt(wDec)*rowones;
    phiB = pinv(trans(wolsDecX%xMM1) * (wolsDecX%xMM1)) * trans(wolsDecX%xMM1) * (wolsDec%yVM1);
  }
  // Check stationarity 
  double Del = 1 - 0.0001;
  arma::vec pl = arma::join_cols(arma::vec{1}, -phiB);
  arma::cx_vec r = roots(pl);
  arma::uvec indices = find(abs(r) >= 1);
  r.elem(indices) = sign(r.elem(indices)) * Del;
  arma::vec polyc = real(as<arma::vec>(polyR(r)));
  phiB = -polyc.subvec(1, polyc.n_elem - 1);
  
  // ----- compute sigma_v
  arma::vec phigB = trans(phiB) * xMM1.submat(0, xMM1.n_cols - 1, p - 1, xMM1.n_cols - 1);
  double s_vh2_ols;
  if (p == 1) {
    s_vh2_ols = (1 - pow(phiB(0), 2)) * (as_scalar(arma::var(y)) - pow(arma::datum::pi, 2) / 2);
  } else {
    s_vh2_ols = as_scalar(arma::var(y)) - pow(arma::datum::pi, 2) / 2 - phigB(0);
  }
  double s_vh_ols;
  if (s_vh2_ols<0){
    s_vh_ols = 0.01;
  }else{
    s_vh_ols = sqrt(s_vh2_ols);
  }
  
  // ----- Organize output
  List para = List::create(
    Named("mu") = mu,
    Named("phi") = phiB,
    Named("sigv") = s_vh_ols,
    Named("sigy") = s_yh,
    Named("nonstationary_ind") = (indices.n_elem > 0)
  );
  
  // ----- return output
  return para;
}





// [[Rcpp::export]]
arma::uvec Get_MBB_ID_cpp(int Ts, int L) {
  // Initialize the vector to store IDs
  arma::uvec id(Ts, arma::fill::zeros);
  
  // Set the random seed to match R's random number generator
  // This assumes you have set the seed in R using set.seed(123)
  // Rcpp does not directly control R's random seed, but you can synchronize
  // by ensuring the seed is set before calling this function in R
  
  // Generate the first ID
  id[0] = std::ceil(Ts * R::runif(0.0, 1.0));
  
  // Generate IDs
  for (int t = 1; t < Ts; ++t) {
    if ((t+1) % L == 0) {
      id[t] = std::ceil(Ts * R::runif(0.0, 1.0));
    } else {
      id[t] = id[t - 1] + 1;
    } 
    
    if (id[t] > Ts) {
      id[t] = 1;
    }
  } 
  
  return id;
} 


// [[Rcpp::export]]
arma::vec QS_Weights_cpp(arma::vec x) {
  arma::vec argQS = 6 * M_PI * x / 5;            // Calculate argument for QS
  arma::vec w1 = 3 / square(argQS);               // w1 = 3 / (argQS^2)
  arma::vec w2 = (sin(argQS) / argQS) - cos(argQS); // w2 = (sin(argQS)/argQS) - cos(argQS)
  arma::vec wQS = w1 % w2;                        // wQS = w1 * w2 (element-wise multiplication)
  
  // Replace 0s in wQS with 1 (same as wQS[wQS == 0] <- 1 in R)
  wQS.elem(find(wQS == 0)).ones();
  
  return wQS;
}


// [[Rcpp::export]]
arma::rowvec QS_cpp(arma::mat y) {
  // Returns column-wise QS HAC estimator of the variance
  int TT = y.n_rows;
  int N = y.n_cols;
  double bw = 1.3 * std::pow(TT, 1.0 / 5.0);
  
  // Compute QS weights
  arma::vec weight = QS_Weights_cpp(arma::linspace(1, TT - 1, TT - 1) / bw);
  
  arma::rowvec omega(N, arma::fill::zeros); // Initialize the output vector with zeros
  
  for (int i = 0; i < N; ++i) {
    arma::vec workdata = y.col(i) - mean(y.col(i));  // Demean the data
    omega(i) = dot(workdata, workdata) / TT;         // First part of omega
    
    // Sum the lagged autocovariances with QS weights
    for (int j = 1; j < TT; ++j) {
      omega(i) += 2 * weight(j - 1) * dot(workdata.subvec(0, TT - j - 1), workdata.subvec(j, TT - 1)) / TT;
    }
  }
  
  return omega;
}




// [[Rcpp::export]]
arma::rowvec MBB_Variance_cpp(arma::mat y, int L) {
  int Ts = y.n_rows;  // Number of rows (time series length)
  int N = y.n_cols;   // Number of columns (series)
  
  arma::rowvec omega(N, arma::fill::zeros);  // Resultant row vector for storing variances
  
  // Demeaning the data column-wise
  arma::mat ydem = y.each_row() - arma::mean(y, 0);  // Subtract column means from each element
  
  int K = std::floor(Ts / L);  // Number of blocks
  
  // Check for valid block size
  if (L <= 0 || K <= 0) {
    stop("Block size L must be positive and should divide the number of rows.");
  }
  
  // Loop over each column (series)
  for (int n = 0; n < N; ++n) {
    // Extract the relevant portion of the matrix and reshape it into KxL blocks
    arma::mat temp = reshape(ydem.submat(0, n, K*L - 1, n), K, L);
    
    // Compute the variance estimator for the column
    omega(n) = arma::mean(arma::sum(temp, 1) % arma::sum(temp, 1)) / L;
  } 
  
  return omega;
}




// [[Rcpp::export]]
Rcpp::List Bootstrap_uSPA_cpp(arma::mat LossDiff, int L = 3, int B = 999) {
  int Ts = LossDiff.n_rows;
  double Ts_dbl = static_cast<double>(Ts);
  
  arma::rowvec d_ij = arma::mean(LossDiff, 0);
  arma::rowvec QS_result = QS_cpp(LossDiff);
  double t_uSPA = arma::min(sqrt(Ts_dbl) * d_ij / sqrt(QS_result));
   
  // Initialize bootstrap statistics vector
  arma::vec t_uSPA_b(B); 
  arma::mat Demeaned_Loss_Diff = LossDiff.each_row() - d_ij;
  // Perform bootstrap sampling
  for (int b = 0; b < B; ++b) {
    arma::uvec id = (Get_MBB_ID_cpp(Ts, L)-1);
    arma::mat b_lossdiff = Demeaned_Loss_Diff.rows(id);
    arma::rowvec omega_b = MBB_Variance_cpp(b_lossdiff, L);
    t_uSPA_b(b) = arma::min(sqrt(Ts_dbl) * arma::mean(b_lossdiff, 0) / sqrt(omega_b));
  }
  // Return results
  return Rcpp::List::create(
    Rcpp::Named("t_uSPA") = t_uSPA,
    Rcpp::Named("t_uSPA_b") = t_uSPA_b
  );
}


// [[Rcpp::export]]
Rcpp::List Bootstrap_aSPA_cpp(arma::mat LossDiff, arma::rowvec weights, int L = 3, int B = 999) {
  int Ts = LossDiff.n_rows;
  double Ts_dbl = static_cast<double>(Ts); 
  
  arma::vec weighted_Loss_Diff = arma::sum(LossDiff.each_row() % weights, 1);
  double d_ij = arma::mean(weighted_Loss_Diff);
  double t_aSPA = sqrt(Ts_dbl) * d_ij / sqrt(arma::as_scalar(QS_cpp(weighted_Loss_Diff)));
  
  // Initialize bootstrap statistics vector
  arma::vec t_aSPA_b(B); 
  arma::vec demeaned_Loss_Diff = weighted_Loss_Diff - d_ij;
  // Perform bootstrap sampling
  for (int b = 0; b < B; ++b) {
    arma::uvec id = (Get_MBB_ID_cpp(Ts, L)-1);
    arma::vec b_lossdiff = demeaned_Loss_Diff.elem(id);
    t_aSPA_b(b) = sqrt(Ts_dbl) * arma::mean(b_lossdiff) / sqrt(arma::as_scalar(MBB_Variance_cpp(b_lossdiff, L)));
  }
   
  // Return results
  return Rcpp::List::create(
    Rcpp::Named("t_aSPA") = t_aSPA,
    Rcpp::Named("t_aSPA_b") = t_aSPA_b
  );
} 





// [[Rcpp::export]]
Rcpp::List MultiHorizonMCS_boot(arma::field<arma::mat> Losses,
                                double alpha_t = 0.05,
                                double alpha_mcs = 0.05,
                                arma::rowvec weights = arma::rowvec(),
                                int L = 3,
                                int B = 999,
                                std::string unif_or_average = "u") {
  
  Environment stats("package:stats");
  Function quantile = stats["quantile"];
  
  int Mmethods = Losses.n_elem;
  int Trows = Losses[0].n_rows;
  double Trows_dbl = static_cast<double>(Trows); 
  
  arma::cube t_SPA_b(Mmethods, Mmethods, B, arma::fill::zeros);
  arma::cube c_SPA_b(Mmethods, Mmethods, B, arma::fill::zeros);
  
  // Perform the calculations
  for (int b = 0; b < B; ++b) { 
    arma::uvec id = Get_MBB_ID_cpp(Trows, L) - 1; 
    for (int i = 0; i < Mmethods; ++i) {
      for (int j = 0; j < Mmethods; ++j) {
        if (i != j) {
          arma::mat LossDiff = Losses[i] - Losses[j];
          if (unif_or_average == "a") {
            arma::vec LossDiffWeighted = arma::sum(LossDiff.each_row() % weights, 1);
            
            arma::vec Demeaned_Loss_Diff = LossDiffWeighted - arma::mean(LossDiffWeighted);
            arma::vec Demeaned_Loss_Diff_Bootstrap = Demeaned_Loss_Diff.elem(id);
            double d_ij = arma::mean(Demeaned_Loss_Diff_Bootstrap);
            double t_SPA_temp = sqrt(Trows_dbl) * d_ij / sqrt(arma::as_scalar(QS_cpp(Demeaned_Loss_Diff_Bootstrap)));
            // Bootstrap loop
            arma::vec t_SPA_b_temp(B, arma::fill::zeros);
            for (int b2 = 0; b2 < B; ++b2) {
              arma::uvec id2 = Get_MBB_ID_cpp(Trows, L) - 1;
              arma::vec b_lossdiff = Demeaned_Loss_Diff.elem(id2);
              t_SPA_b_temp(b2) = sqrt(Trows_dbl) * arma::mean(b_lossdiff) / sqrt(arma::as_scalar(MBB_Variance_cpp(b_lossdiff, L)));
            }
            t_SPA_b(i, j, b) = t_SPA_temp;
            c_SPA_b(i, j, b) = as<double>(quantile(t_SPA_b_temp, alpha_t));
          } else { 
            arma::mat Demeaned_Loss_Diff = (LossDiff.each_row() - arma::mean(LossDiff, 0));
            arma::mat Demeaned_Loss_Diff_Bootstrap = Demeaned_Loss_Diff.rows(id);
            arma::rowvec d_ij = arma::mean(Demeaned_Loss_Diff_Bootstrap, 0);
            double t_SPA_temp = min(sqrt(Trows_dbl) * d_ij / sqrt(QS_cpp(Demeaned_Loss_Diff_Bootstrap)));
            
            // Bootstrap loop
            arma::vec t_SPA_b_temp(B, arma::fill::zeros);
            for (int b2 = 0; b2 < B; ++b2) {
              arma::uvec id2 = Get_MBB_ID_cpp(Trows, L) - 1;
              arma::mat b_lossdiff = Demeaned_Loss_Diff_Bootstrap.rows(id2);
              t_SPA_b_temp(b2) = min(sqrt(Trows_dbl) * arma::mean(b_lossdiff, 0) / sqrt(MBB_Variance_cpp(b_lossdiff, L)));
            } 
            
            t_SPA_b(i, j, b) = t_SPA_temp;
            c_SPA_b(i, j, b) = as<double>(quantile(t_SPA_b_temp, alpha_t));
          }
        }
      } 
    }
  }
  
  // Return the results
  return Rcpp::List::create(
    Rcpp::Named("t_SPA_b") = t_SPA_b,
    Rcpp::Named("c_SPA_b") = c_SPA_b
  );
}











// [[Rcpp::export]]
Rcpp::List MultiHorizonMCS_cpp(Rcpp::List Losses,
                           double alpha_t = 0.05,
                           double alpha_mcs = 0.05,
                           Rcpp::Nullable<Rcpp::NumericVector> weights = R_NilValue, 
                           int L = 3, 
                           int B = 999,
                           std::string unif_or_average = "u") {
  
  Function quantileR = Environment::base_env()["quantile"];
  
  
  if (!(unif_or_average == "a" || unif_or_average == "u")) {
    Rcpp::stop("unif_or_average must equal 'u' for uniform or 'a' for average.");
  } 
  
  int Mmethods = Losses.size();
  int Trows = Rcpp::as<arma::mat>(Losses[0]).n_rows;
  int Hcols = Rcpp::as<arma::mat>(Losses[0]).n_cols;
  
  double Trows_dbl = static_cast<double>(Trows); 
  
  arma::vec p_values = arma::zeros(Mmethods);
  arma::uvec IDs = arma::regspace<arma::uvec>(0, Mmethods - 1);
  
  arma::rowvec weight_vec;
  if (unif_or_average == "a" && weights.isNull()) {
    weight_vec = arma::ones(Hcols) / Hcols;
  } else {  
    weight_vec = Rcpp::as<arma::rowvec>(weights);
  }  
  
  arma::mat t_uSPA = arma::zeros(Mmethods, Mmethods);
  arma::mat c_uSPA = arma::zeros(Mmethods, Mmethods);
  
  for (int i = 0; i < Mmethods; ++i) {
    for (int j = 0; j < Mmethods; ++j) {
      if (i != j) {
        arma::mat LossDiff = Rcpp::as<arma::mat>(Losses[i]) - Rcpp::as<arma::mat>(Losses[j]);
        Rcpp::List bootout;
        if (unif_or_average == "u") {
          bootout = Bootstrap_uSPA_cpp(LossDiff, L, B);
          t_uSPA(i, j) = bootout["t_uSPA"];
        } else {  
          bootout = Bootstrap_aSPA_cpp(LossDiff, weight_vec, L, B);
          t_uSPA(i, j) = bootout["t_aSPA"];
        }  
        c_uSPA(i, j) = as<double>(quantileR(Rcpp::as<arma::vec>(bootout["t_uSPA_b"]), alpha_t));
      } 
    }
  } 
  
  arma::cube t_uSPA_b(Mmethods, Mmethods, B, arma::fill::zeros);
  arma::cube c_uSPA_b(Mmethods, Mmethods, B, arma::fill::zeros);
  
  for (int b = 0; b < B; ++b) {
    arma::uvec id = Get_MBB_ID_cpp(Trows, L)-1;
    for (int i = 0; i < Mmethods; ++i) {
      for (int j = 0; j < Mmethods; ++j) {
        if (i != j) {
          arma::mat LossDiff = Rcpp::as<arma::mat>(Losses[i]) - Rcpp::as<arma::mat>(Losses[j]);
          arma::mat Demeaned_Loss_Diff;
          arma::vec d_ij;
          double t_uSPA_temp;
          
          if (unif_or_average == "a") {
            LossDiff.each_row() %= weight_vec.t();
            Demeaned_Loss_Diff = (LossDiff - arma::mean(LossDiff)) / Trows_dbl;
            Demeaned_Loss_Diff = Demeaned_Loss_Diff.rows(id);
            d_ij = arma::mean(Demeaned_Loss_Diff);
            t_uSPA_temp = arma::as_scalar(sqrt(Trows_dbl) * d_ij / sqrt(QS_cpp(Demeaned_Loss_Diff)));
          } else { 
            Demeaned_Loss_Diff = LossDiff.each_row() - arma::mean(LossDiff);
            Demeaned_Loss_Diff = Demeaned_Loss_Diff.rows(id);
            d_ij = arma::mean(Demeaned_Loss_Diff, 0);
            t_uSPA_temp = arma::min(sqrt(Trows_dbl) * d_ij / sqrt(QS_cpp(Demeaned_Loss_Diff)));
          }
          
          arma::vec t_uSPA_b_temp(B, arma::fill::zeros);
          for (int b2 = 0; b2 < B; ++b2) {
            arma::uvec id2 = Get_MBB_ID_cpp(Trows, L)-1;
            arma::mat b_lossdiff = Demeaned_Loss_Diff.rows(id2);
            double omega_b = arma::as_scalar(MBB_Variance_cpp(b_lossdiff, L));
            if (unif_or_average == "a") {
              t_uSPA_b_temp(b2) = arma::as_scalar(sqrt(Trows_dbl) * arma::mean(b_lossdiff) / sqrt(omega_b));
            } else {
              t_uSPA_b_temp(b2) = arma::min(sqrt(Trows_dbl) * arma::mean(b_lossdiff) / sqrt(omega_b));
            }
          } 
          
          t_uSPA_b(i, j, b) = t_uSPA_temp;
          c_uSPA_b(i, j, b) = as<double>(quantileR(t_uSPA_b_temp, alpha_t));
        }
      } 
    } 
  }
  
  while (Mmethods > 0) {
    arma::vec t_max_uSPA = arma::max(t_uSPA - c_uSPA, 1);
    arma::vec t_max_uSPA_b = arma::max(t_uSPA_b - c_uSPA_b, 1);
    
    arma::mat crits = t_uSPA - c_uSPA - 9999999 * arma::eye(Mmethods, Mmethods);
    arma::uword index = crits.index_max();
    
    double p_temp = arma::mean(t_max_uSPA < t_max_uSPA_b);
    p_values(IDs(index)) = std::max(p_temp, p_values.max());
    
    if (IDs.n_elem == 1) {
      p_values(IDs(index)) = 1;
    }  
    
    IDs.shed_row(index);
    Losses.erase(index);
    
    t_uSPA.shed_row(index);
    t_uSPA.shed_col(index);
    c_uSPA.shed_row(index);
    c_uSPA.shed_col(index);
    t_uSPA_b.shed_row(index);
    t_uSPA_b.shed_col(index);
    c_uSPA_b.shed_row(index);
    c_uSPA_b.shed_col(index);
    
    --Mmethods;
  }  
  
  arma::mat MCS_set = arma::join_horiz(arma::regspace(0, Losses.size() - 1), p_values);
  MCS_set = MCS_set.rows(arma::find(MCS_set.col(1) >= (1 - alpha_mcs)));
  
  return Rcpp::List::create(Rcpp::Named("MCS_set") = MCS_set, 
                            Rcpp::Named("p_values") = p_values);
} 

