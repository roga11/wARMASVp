}
}
# Also: sample size effect at sweet spot
cat("\n  Sample size effect at phi=0.90, sigv=0.50\n")
Tvals <- c(500, 1000, 2000, 5000, 10000)
res_T_sv1 <- data.frame(Tsize = numeric(), bias = numeric(), rmse = numeric())
for (T_i in Tvals) {
rho_est <- numeric(0); xb <- 0
while (xb < B) {
sim <- sim_svp(T_i, phi = 0.90, sigy = 0.15, sigv = 0.50,
leverage = TRUE, rho = rho_true, burnin = burnin)
mdl <- tryCatch(
svp(sim$y, p = 1, J = J, leverage = TRUE, rho_type = "pearson",
del = del, trunc_lev = FALSE, wDecay = FALSE),
error = function(e) NULL
)
if (!is.null(mdl) && !is.na(mdl$rho) && is.finite(mdl$rho)) {
rho_est <- c(rho_est, max(-1, min(1, mdl$rho))); xb <- xb + 1
}
}
res_T_sv1 <- rbind(res_T_sv1, data.frame(
Tsize = T_i,
bias = mean(rho_est) - rho_true,
rmse = sqrt(mean((rho_est - rho_true)^2))))
}
print(res_T_sv1)
# Write table_leverage_sensitivity.tex
sink(file.path(paper_dir, "tables/table_leverage_sensitivity.tex"))
cat("\\begin{table}[htbp]\n\\centering\n")
cat("\\caption{Sensitivity of leverage estimation to $\\tilde{\\gamma}_p$ ($\\delta_p = -0.9$, $\\sigma_y = 0.15$, $T = 2{,}000$, $B =", B, "$, $J =", J, "$).}\n", sep = " ")
cat("\\label{tab:leverage_sensitivity}\n\\small\n")
cat("\\begin{tabular}{cccc c cc c cc c c}\n\\hline\\hline\n")
cat(" & & & & & \\multicolumn{2}{c}{$\\hat{\\delta}_p$} & & \\multicolumn{2}{c}{$\\hat{\\phi}$} & & $\\hat{\\sigma}_v$ \\\\\n")
cat("\\cline{6-7} \\cline{9-10}\n")
cat("$\\phi$ & $\\sigma_v$ & $\\tilde{\\gamma}_p$ & $e^{-\\tilde{\\gamma}_p/4}$ & & Bias & RMSE & & Bias & RMSE & & RMSE \\\\\n\\hline\n")
for (i in 1:nrow(sens_sv1)) {
r <- sens_sv1[i, ]
cat(sprintf("%.2f & %.2f & %.1f & %.3f & & %.3f & %.3f & & %.4f & %.4f & & %.4f \\\\\n",
r$phi, r$sigv, r$gammatilde, r$exp_factor,
r$bias, r$rmse, r$bias_phi, r$rmse_phi, r$rmse_sigv))
if (i < nrow(sens_sv1) && sens_sv1$phi[i + 1] != r$phi) cat("\\hline\n")
}
cat("\\hline\n\\end{tabular}\n\\end{table}\n")
sink()
cat("  -> table_leverage_sensitivity.tex written\n\n")
# ============================================================================ #
# LEVERAGE SENSITIVITY: SV(2)                                             ----
# (produces table_leverage_sensitivity_sv2.tex + data for Figure 1 panels c,d)
# ============================================================================ #
cat("====== LEVERAGE SENSITIVITY: SV(2) ======\n")
# Match SV(1) spectral radii: for AR(2) with phi1=0.05, phi2 = lambda*(lambda - phi1)
phi1_sv2 <- 0.05
lambda_targets <- c(0.75, 0.90, 0.95, 0.98)
configs_sv2 <- lapply(lambda_targets, function(lam) {
phi2 <- lam * (lam - phi1_sv2)
list(phi1 = phi1_sv2, phi2 = phi2, sigv_vals = sigv_vals)
})
sens_sv2 <- data.frame(phi1 = numeric(), phi2 = numeric(), sigv = numeric(),
largest_root = numeric(), gammatilde = numeric(),
exp_factor = numeric(),
bias_delta = numeric(), rmse_delta = numeric(),
bias_phi1 = numeric(), rmse_phi1 = numeric(),
bias_phi2 = numeric(), rmse_phi2 = numeric(),
rmse_sigv = numeric())
for (cfg in configs_sv2) {
phi1 <- cfg$phi1; phi2 <- cfg$phi2
for (sigv in cfg$sigv_vals) {
gt <- sigv^2 / ((1 - phi1 - phi2) * (1 + phi2))
if (gt > 60) next
cat(sprintf("  phi1=%.2f, phi2=%.2f, sigv=%.2f (gt=%.1f)\n",
phi1, phi2, sigv, gt))
delta_est <- phi1_est <- phi2_est <- sigv_est <- numeric(0)
xb <- 0; attempts <- 0
while (xb < B && attempts < B * 5) {
attempts <- attempts + 1
sim <- sim_svp(Tsize_sens, phi = c(phi1, phi2), sigy = 1.0,
sigv = sigv, leverage = TRUE,
rho = rho_true, burnin = burnin)
mdl <- tryCatch(
svp(sim$y, p = 2, J = J, leverage = TRUE, rho_type = "pearson",
del = del, trunc_lev = FALSE, wDecay = FALSE),
error = function(e) NULL
)
if (!is.null(mdl) && !is.na(mdl$rho) && is.finite(mdl$rho) &&
all(!is.na(mdl$theta))) {
delta_est <- c(delta_est, max(-1, min(1, mdl$rho)))
phi1_est <- c(phi1_est, mdl$phi[1])
phi2_est <- c(phi2_est, mdl$phi[2])
sigv_est <- c(sigv_est, mdl$sigv)
xb <- xb + 1
}
}
if (length(delta_est) >= B / 2) {
lr <- max(abs(polyroot(c(-phi2, -phi1, 1))))
sens_sv2 <- rbind(sens_sv2, data.frame(
phi1 = phi1, phi2 = phi2, sigv = sigv, largest_root = lr,
gammatilde = gt, exp_factor = exp(-gt / 4),
bias_delta = mean(delta_est) - rho_true,
rmse_delta = sqrt(mean((delta_est - rho_true)^2)),
bias_phi1 = mean(phi1_est) - phi1,
rmse_phi1 = sqrt(mean((phi1_est - phi1)^2)),
bias_phi2 = mean(phi2_est) - phi2,
rmse_phi2 = sqrt(mean((phi2_est - phi2)^2)),
rmse_sigv = sqrt(mean((sigv_est - sigv)^2))
))
}
}
}
# Write table_leverage_sensitivity_sv2.tex
sink(file.path(paper_dir, "tables/table_leverage_sensitivity_sv2.tex"))
cat("\\begin{table}[htbp]\n\\centering\n")
cat("\\caption{Sensitivity of SV(2) leverage estimation to $\\tilde{\\gamma}_p$ ($\\delta_p = -0.9$, $\\sigma_y = 1.0$, $T = 2{,}000$, $B =", B, "$, $J =", J, "$).}\n", sep = " ")
cat("\\label{tab:leverage_sensitivity_sv2}\n\\small\n")
cat("\\adjustbox{max width=\\textwidth}{%\n")
cat("\\begin{tabular}{cccccc c cc c cc c c}\n\\hline\\hline\n")
cat(" & & & & & & & \\multicolumn{2}{c}{$\\hat{\\delta}_p$} & & \\multicolumn{2}{c}{$\\hat{\\phi}_2$} & & $\\hat{\\sigma}_v$ \\\\\n")
cat("\\cline{8-9} \\cline{11-12}\n")
cat("$\\phi_1$ & $\\phi_2$ & $\\lambda_{\\max}$ & $\\sigma_v$ & $\\tilde{\\gamma}_p$ & $e^{-\\tilde{\\gamma}_p/4}$ & & Bias & RMSE & & Bias & RMSE & & RMSE \\\\\n\\hline\n")
prev_combo <- ""
for (i in 1:nrow(sens_sv2)) {
r <- sens_sv2[i, ]
cur_combo <- paste(r$phi1, r$phi2)
if (cur_combo != prev_combo && prev_combo != "") cat("\\hline\n")
prev_combo <- cur_combo
cat(sprintf("%.2f & %.2f & %.2f & %.2f & %.1f & %.3f & & %.3f & %.3f & & %.4f & %.4f & & %.4f \\\\\n",
r$phi1, r$phi2, r$largest_root, r$sigv, r$gammatilde, r$exp_factor,
r$bias_delta, r$rmse_delta, r$bias_phi2, r$rmse_phi2, r$rmse_sigv))
}
cat("\\hline\n\\end{tabular}}\n\\end{table}\n")
sink()
cat("  -> table_leverage_sensitivity_sv2.tex written\n\n")
# ============================================================================ #
# FIGURE 1: Leverage Sensitivity (combined SV(1) + SV(2))                 ----
# (4 panels: SV(1) Bias, SV(1) RMSE, SV(2) Bias, SV(2) RMSE)
# ============================================================================ #
cat("====== FIGURE 1: Leverage sensitivity (combined) ======\n")
# --- Compute spectral radius for each SV(2) row ---
sens_sv2$lambda <- sapply(1:nrow(sens_sv2), function(i) {
max(abs(polyroot(c(-sens_sv2$phi2[i], -sens_sv2$phi1[i], 1))))
})
# --- Common lambda labels (spectral radius) ---
# For SV(1), lambda = phi; for SV(2), lambda = largest root
lambda_fmt <- function(x) sprintf("%.2f", x)
df_sv1 <- data.frame(
gammatilde = sens_sv1$gammatilde,
bias = sens_sv1$bias,
rmse = sens_sv1$rmse,
lambda = sens_sv1$phi,
lambda_label = factor(paste0("lambda == ", lambda_fmt(sens_sv1$phi)))
)
df_sv2 <- data.frame(
gammatilde = sens_sv2$gammatilde,
bias = sens_sv2$bias_delta,
rmse = sens_sv2$rmse_delta,
lambda = sens_sv2$lambda,
lambda_label = factor(paste0("lambda == ", lambda_fmt(sens_sv2$lambda)))
)
# Ensure same factor levels across both datasets for consistent colors
all_levels <- paste0("lambda == ", lambda_fmt(lambda_targets))
df_sv1$lambda_label <- factor(df_sv1$lambda_label, levels = all_levels)
df_sv2$lambda_label <- factor(df_sv2$lambda_label, levels = all_levels)
# Common ggplot theme
theme_paper <- theme_bw(base_size = 12) +
theme(panel.grid.major = element_line(colour = "grey90", linewidth = 0.3),
panel.grid.minor = element_line(colour = "grey95", linewidth = 0.15),
legend.background = element_rect(fill = alpha("white", 0.8)),
legend.text = element_text(size = fig_legend_size),
legend.key.width = unit(fig_legend_keywidth, "lines"),
axis.text = element_text(size = fig_tick_size),
axis.title = element_text(size = fig_axislab_size),
plot.title = element_text(size = fig_subtitle_size, face = "bold"))
# Color and shape palettes (4 levels, consistent across all panels)
col_pal5 <- c("#F8766D", "#00BF7D", "#00B0F6", "#E76BF3")
shp_pal5 <- c(16, 17, 15, 18)
# Legend labels using plotmath expressions for Greek letters in PDF
# SV(1): just phi value, no extra lines
sv1_legend <- setNames(
lapply(lambda_targets, function(lam) {
bquote(phi == .(sprintf("%.2f", lam)))
}),
all_levels
)
# SV(2): multi-line legend labels using atop()
sv2_legend <- setNames(
lapply(lambda_targets, function(lam) {
phi2 <- lam * (lam - phi1_sv2)
bquote(atop(
phi == group("(", list(.(sprintf("%.2f", phi1_sv2)),
.(sprintf("%.2f", phi2))), ")"),
lambda == .(sprintf("%.2f", lam))
))
}),
all_levels
)
# Empirical range annotation (same for all panels)
emp_range <- annotate("rect", xmin = 0.5, xmax = 3.0,
ymin = -Inf, ymax = Inf,
fill = "darkgreen", alpha = 0.08)
# Helper to build a panel (with or without legend)
make_panel <- function(df, y_var, y_lab, title_str, legend_labels,
show_legend = TRUE) {
p <- ggplot(df, aes(x = gammatilde, y = .data[[y_var]],
colour = lambda_label, shape = lambda_label)) +
emp_range +
geom_hline(yintercept = 0, linetype = "dashed", colour = "gray50") +
geom_line(linewidth = 0.8) + geom_point(size = 2.5) +
scale_colour_manual(values = col_pal5, labels = legend_labels,
drop = FALSE) +
scale_shape_manual(values = shp_pal5, labels = legend_labels,
drop = FALSE) +
coord_cartesian(xlim = c(0, 10), ylim = c(-0.05, 0.85)) +
labs(x = expression(tilde(gamma)[p]), y = y_lab,
title = title_str, colour = NULL, shape = NULL) +
guides(colour = guide_legend(
override.aes = list(linewidth = fig_legend_linewidth,
size = fig_legend_ptsize)),
shape  = guide_legend(
override.aes = list(linewidth = fig_legend_linewidth,
size = fig_legend_ptsize))) +
theme_paper
if (!show_legend) p <- p + theme(legend.position = "none")
p
}
# Extract shared legend from a panel
extract_legend <- function(p) {
g <- ggplotGrob(p + theme(legend.position = "right"))
leg <- g$grobs[sapply(g$grobs, function(x) x$name) == "guide-box"]
if (length(leg) > 0) leg[[1]] else grid::nullGrob()
}
# Build panels without individual legends
p_a <- make_panel(df_sv1, "bias",
expression("Bias of " * hat(delta)[p]),
"(a) SV(1): Bias", sv1_legend, show_legend = FALSE)
p_b <- make_panel(df_sv1, "rmse",
expression("RMSE of " * hat(delta)[p]),
"(b) SV(1): RMSE", sv1_legend, show_legend = FALSE)
p_c <- make_panel(df_sv2, "bias",
expression("Bias of " * hat(delta)[p]),
"(c) SV(2): Bias", sv2_legend, show_legend = FALSE)
p_d <- make_panel(df_sv2, "rmse",
expression("RMSE of " * hat(delta)[p]),
"(d) SV(2): RMSE", sv2_legend, show_legend = FALSE)
# Extract one shared legend per row
leg_sv1 <- extract_legend(
make_panel(df_sv1, "bias", "", "", sv1_legend, show_legend = TRUE))
leg_sv2 <- extract_legend(
make_panel(df_sv2, "bias", "", "", sv2_legend, show_legend = TRUE))
# Combine: [panel_a | panel_b | legend_sv1] / [panel_c | panel_d | legend_sv2]
library(gridExtra)
row1 <- arrangeGrob(p_a, p_b, leg_sv1, ncol = 3, widths = c(1, 1, 0.35))
row2 <- arrangeGrob(p_c, p_d, leg_sv2, ncol = 3, widths = c(1, 1, 0.35))
fig1 <- arrangeGrob(row1, row2, nrow = 2)
ggsave(file.path(paper_dir, "figures/figure_leverage_sensitivity.pdf"),
fig1, width = 13, height = 10)
cat("  -> figure_leverage_sensitivity.pdf written\n\n")
# ============================================================================ #
# Done                                                                    ----
# ============================================================================ #
cat("====== ALL DONE ======\n")
cat("Tables: table1.tex, table2.tex, table3.tex, table4.tex\n")
cat("        table_leverage_sensitivity.tex, table_leverage_sensitivity_sv2.tex\n")
cat("Figures: figure_leverage_sensitivity.pdf\n")
## ============================================================================ #
## SV(2) Heavy-Tail Simulation Script
## Produces: Appendix Tables A1 (Student-t SV(2)) and A2 (GED SV(2))
## SV(2) DGPs are chosen to match persistence (largest root) of SV(1) DGPs
## in main Tables 3 and 4.
## ============================================================================ #
rm(list = ls())
library(wARMASVp)
# Paper directory
paper_dir <- "~/Dropbox/Res/papers/SVp_Rpack/paper"
cat(sprintf("Paper directory: %s\n", paper_dir))
dir.create(file.path(paper_dir, "tables"), showWarnings = FALSE)
set.seed(535725)
# ============================================================================ #
# Global Settings (same as run_simulations.R)
# ============================================================================ #
B      <- 1000
burnin <- 500
del    <- 1e-6
wDecay <- FALSE
J      <- 100
Tsize_ls <- c(500, 1000, 2000, 5000)
fmt <- function(x) sprintf("%.4f", x)
fmt_or_dash <- function(x) if (is.na(x)) "---" else sprintf("%.4f", x)
# Boundary values for heavy-tail nu estimation
nu_bound_t  <- c(lower = 2.01, upper = 500)
nu_bound_ged <- c(lower = 0.1, upper = 20)
is_boundary_t <- function(v) v <= nu_bound_t["lower"] | v >= nu_bound_t["upper"]
is_boundary_ged <- function(v) v <= nu_bound_ged["lower"] | v >= nu_bound_ged["upper"]
largest_root <- function(phi) {
p <- length(phi)
if (p == 1) return(abs(phi))
max(abs(polyroot(c(-rev(phi), 1))))
}
cat("=== SV(2) Heavy-Tail Simulations ===\n")
cat(sprintf("B=%d, J=%d, burnin=%d, T={%s}\n",
B, J, burnin, paste(Tsize_ls, collapse = ",")))
cat(sprintf("del=%g\n\n", del))
# ============================================================================ #
# DGP Design: SV(2) matching SV(1) persistence
#
# SV(1) DGPs:
#   Medium persistence: phi = 0.90 (root = 0.90)
#   High persistence:   phi = 0.95 (root = 0.95)
#
# SV(2) DGPs: phi2 = root * (root - phi1), with phi1 = 0.20
#   Medium: phi = (0.20, 0.6300), root = 0.90
#   High:   phi = (0.20, 0.7125), root = 0.95
# ============================================================================ #
# Exact phi2 values for precise root matching
phi2_medium <- 0.90 * (0.90 - 0.20)  # = 0.63
phi2_high   <- 0.95 * (0.95 - 0.20)  # = 0.7125
cat(sprintf("SV(2) Medium: phi=(0.20, %.4f), root=%.4f\n",
phi2_medium, largest_root(c(0.20, phi2_medium))))
cat(sprintf("SV(2) High:   phi=(0.20, %.4f), root=%.4f\n\n",
phi2_high, largest_root(c(0.20, phi2_high))))
# ============================================================================ #
# TABLE A1: Student-t SV(2)                                                ----
# ============================================================================ #
cat("====== TABLE A1: Student-t SV(2) ======\n")
dgp_tabA1 <- list(
list(phi = c(0.20, phi2_medium), sigy = 1.0, sigv = 1.0, nu = 3,
persist = "Medium"),
list(phi = c(0.20, phi2_high),   sigy = 1.0, sigv = 1.0, nu = 3,
persist = "High"),
list(phi = c(0.20, phi2_medium), sigy = 1.0, sigv = 1.0, nu = 10,
persist = "Medium"),
list(phi = c(0.20, phi2_high),   sigy = 1.0, sigv = 1.0, nu = 10,
persist = "High")
)
results_tabA1 <- list()
for (dgp in dgp_tabA1) {
true_theta <- c(dgp$phi, dgp$sigy, dgp$sigv, dgp$nu)
n_par <- 5
for (Tsize in Tsize_ls) {
cat(sprintf("  Student-t SV(2) nu=%d, %s pers., T=%d\n",
dgp$nu, dgp$persist, Tsize))
estimsB <- matrix(NA, B, n_par)
xb <- 1
while (xb <= B) {
y <- sim_svp(Tsize, phi = dgp$phi, sigy = dgp$sigy,
sigv = dgp$sigv, errorType = "Student-t",
nu = dgp$nu, burnin = burnin)
mdl <- tryCatch(
suppressWarnings(svp(y, p = 2, J = J, leverage = FALSE,
errorType = "Student-t", del = del,
wDecay = wDecay)),
error = function(e) NULL
)
if (!is.null(mdl)) {
estimsB[xb, ] <- c(mdl$phi, mdl$sigy, mdl$sigv, mdl$v)
xb <- xb + 1
}
}
bias_all <- colMeans(estimsB) - true_theta
rmse_all <- sqrt(colMeans((estimsB - matrix(true_theta, B, n_par,
byrow = TRUE))^2))
interior <- !is_boundary_t(estimsB[, n_par])
bd_rate <- 1 - mean(interior)
if (sum(interior) > 0) {
bias_all[n_par] <- mean(estimsB[interior, n_par]) - dgp$nu
rmse_all[n_par] <- sqrt(mean((estimsB[interior, n_par] - dgp$nu)^2))
} else {
bias_all[n_par] <- NA; rmse_all[n_par] <- NA
}
cat(sprintf("    boundary rate: %.1f%%\n", 100 * bd_rate))
results_tabA1[[length(results_tabA1) + 1]] <- list(
dgp = dgp, Tsize = Tsize, bias = bias_all, rmse = rmse_all, bd_rate = bd_rate)
}
}
# Write tableA1.tex
find_resA1 <- function(dgp, Tsize) {
for (r in results_tabA1) {
if (all(r$dgp$phi == dgp$phi) && r$dgp$nu == dgp$nu &&
r$Tsize == Tsize)
return(r)
}
NULL
}
sink(file.path(paper_dir, "tables/tableA1.tex"))
cat("\\begin{table}[!t]\n\\centering\n")
cat("\\caption{Monte Carlo estimation results: Student-$t$ SV(2) models.}\n")
cat("\\label{tab:student_t_sv2}\n\\small\n")
cat("\\vspace{0.3cm}\n\n")
cat("\\adjustbox{max width=\\textwidth}{%\n")
cat("\\begin{tabular}{l l rrrrr c rrrrr}\n\\hline\\hline\n")
cat(" & & \\multicolumn{5}{c}{Bias} & & \\multicolumn{5}{c}{RMSE} \\\\\n")
cat("\\cline{3-7} \\cline{9-13}\n")
cat("DGP & $T$ & $\\phi_1$ & $\\phi_2$ & $\\sigma_y$ & $\\sigma_v$ & $\\nu$ & & $\\phi_1$ & $\\phi_2$ & $\\sigma_y$ & $\\sigma_v$ & $\\nu$ \\\\\n\\hline\n")
for (dgp in dgp_tabA1) {
nu_label <- if (dgp$nu == 3) "Heavy tails" else "Moderate tails"
cat(sprintf("\\multirow{4}{*}{\\makecell[l]{$\\nu\\!=\\!%d$ (%s),\\\\\\ %s pers.\\\\\\ \\footnotesize True: $\\phi_1\\!=\\!%.2f,\\; \\phi_2\\!=\\!%.2f,$\\\\\\ \\footnotesize $\\sigma_y\\!=\\!%.1f,\\; \\sigma_v\\!=\\!%.1f,\\; \\nu\\!=\\!%d$}}",
dgp$nu, nu_label, dgp$persist,
dgp$phi[1], dgp$phi[2], dgp$sigy, dgp$sigv, dgp$nu))
for (i in seq_along(Tsize_ls)) {
Tsize <- Tsize_ls[i]
res <- find_resA1(dgp, Tsize)
cat(sprintf(" & %d & %s & %s & %s & %s & %s & & %s & %s & %s & %s & %s \\\\\n",
Tsize,
fmt(res$bias[1]), fmt(res$bias[2]), fmt(res$bias[3]),
fmt(res$bias[4]), fmt_or_dash(res$bias[5]),
fmt(res$rmse[1]), fmt(res$rmse[2]), fmt(res$rmse[3]),
fmt(res$rmse[4]), fmt_or_dash(res$rmse[5])))
}
cat("\\hline\n")
}
cat("\\end{tabular}}\n\n")
cat("\\vspace{0.3cm}\n\\begin{minipage}{\\textwidth}\n\\footnotesize\n")
cat("\\textit{Notes:} Bias and RMSE of the W-ARMA-SV estimator for SV(2) models with standardized Student-$t$ innovations, $z_t \\sim t_\\nu/\\sqrt{\\nu/(\\nu-2)}$. The SV(2) DGPs use $\\phi_1 = 0.20$ with $\\phi_2$ chosen so that the largest AR root matches the SV(1) persistence in Table~\\ref{tab:student_t} (root $= 0.90$ for medium, $0.95$ for high persistence). Bias and RMSE for $\\phi_1$, $\\phi_2$, $\\sigma_y$, and $\\sigma_v$ are computed over all $B$ replications; $\\nu$ statistics are reported only for interior solutions. Based on $B = ", B, "$ Monte Carlo replications with $J = ", J, "$ and $\\delta = ", del, "$. $T$ = sample size.\n", sep = "")
cat("\\end{minipage}\n\\end{table}\n")
sink()
cat("  -> tableA1.tex written\n\n")
# ============================================================================ #
# TABLE A2: GED SV(2)                                                      ----
# ============================================================================ #
cat("====== TABLE A2: GED SV(2) ======\n")
dgp_tabA2 <- list(
list(phi = c(0.20, phi2_medium), sigy = 1.0, sigv = 1.0, nu = 1.5,
persist = "Medium"),
list(phi = c(0.20, phi2_high),   sigy = 1.0, sigv = 1.0, nu = 1.5,
persist = "High"),
list(phi = c(0.20, phi2_medium), sigy = 1.0, sigv = 1.0, nu = 1.0,
persist = "Medium"),
list(phi = c(0.20, phi2_high),   sigy = 1.0, sigv = 1.0, nu = 1.0,
persist = "High")
)
results_tabA2 <- list()
for (dgp in dgp_tabA2) {
true_theta <- c(dgp$phi, dgp$sigy, dgp$sigv, dgp$nu)
n_par <- 5
for (Tsize in Tsize_ls) {
cat(sprintf("  GED SV(2) nu=%.1f, %s pers., T=%d\n",
dgp$nu, dgp$persist, Tsize))
estimsB <- matrix(NA, B, n_par)
xb <- 1
while (xb <= B) {
y <- sim_svp(Tsize, phi = dgp$phi, sigy = dgp$sigy,
sigv = dgp$sigv, errorType = "GED",
nu = dgp$nu, burnin = burnin)
mdl <- tryCatch(
suppressWarnings(svp(y, p = 2, J = J, leverage = FALSE,
errorType = "GED", del = del,
wDecay = wDecay)),
error = function(e) NULL
)
if (!is.null(mdl)) {
estimsB[xb, ] <- c(mdl$phi, mdl$sigy, mdl$sigv, mdl$v)
xb <- xb + 1
}
}
bias_all <- colMeans(estimsB) - true_theta
rmse_all <- sqrt(colMeans((estimsB - matrix(true_theta, B, n_par,
byrow = TRUE))^2))
interior <- !is_boundary_ged(estimsB[, n_par])
bd_rate <- 1 - mean(interior)
if (sum(interior) > 0) {
bias_all[n_par] <- mean(estimsB[interior, n_par]) - dgp$nu
rmse_all[n_par] <- sqrt(mean((estimsB[interior, n_par] - dgp$nu)^2))
} else {
bias_all[n_par] <- NA; rmse_all[n_par] <- NA
}
cat(sprintf("    boundary rate: %.1f%%\n", 100 * bd_rate))
results_tabA2[[length(results_tabA2) + 1]] <- list(
dgp = dgp, Tsize = Tsize, bias = bias_all, rmse = rmse_all, bd_rate = bd_rate)
}
}
# Write tableA2.tex
find_resA2 <- function(dgp, Tsize) {
for (r in results_tabA2) {
if (all(r$dgp$phi == dgp$phi) && r$dgp$nu == dgp$nu &&
r$Tsize == Tsize)
return(r)
}
NULL
}
sink(file.path(paper_dir, "tables/tableA2.tex"))
cat("\\begin{table}[!t]\n\\centering\n")
cat("\\caption{Monte Carlo estimation results: GED SV(2) models.}\n")
cat("\\label{tab:ged_sv2}\n\\small\n")
cat("\\vspace{0.3cm}\n\n")
cat("\\adjustbox{max width=\\textwidth}{%\n")
cat("\\begin{tabular}{l l rrrrr c rrrrr}\n\\hline\\hline\n")
cat(" & & \\multicolumn{5}{c}{Bias} & & \\multicolumn{5}{c}{RMSE} \\\\\n")
cat("\\cline{3-7} \\cline{9-13}\n")
cat("DGP & $T$ & $\\phi_1$ & $\\phi_2$ & $\\sigma_y$ & $\\sigma_v$ & $\\nu$ & & $\\phi_1$ & $\\phi_2$ & $\\sigma_y$ & $\\sigma_v$ & $\\nu$ \\\\\n\\hline\n")
for (dgp in dgp_tabA2) {
nu_label <- if (dgp$nu == 1.0) "Laplace" else "Heavy tails"
cat(sprintf("\\multirow{4}{*}{\\makecell[l]{$\\nu\\!=\\!%.1f$ (%s),\\\\\\ %s pers.\\\\\\ \\footnotesize True: $\\phi_1\\!=\\!%.2f,\\; \\phi_2\\!=\\!%.2f,$\\\\\\ \\footnotesize $\\sigma_y\\!=\\!%.1f,\\; \\sigma_v\\!=\\!%.1f,\\; \\nu\\!=\\!%.1f$}}",
dgp$nu, nu_label, dgp$persist,
dgp$phi[1], dgp$phi[2], dgp$sigy, dgp$sigv, dgp$nu))
for (i in seq_along(Tsize_ls)) {
Tsize <- Tsize_ls[i]
res <- find_resA2(dgp, Tsize)
cat(sprintf(" & %d & %s & %s & %s & %s & %s & & %s & %s & %s & %s & %s \\\\\n",
Tsize,
fmt(res$bias[1]), fmt(res$bias[2]), fmt(res$bias[3]),
fmt(res$bias[4]), fmt_or_dash(res$bias[5]),
fmt(res$rmse[1]), fmt(res$rmse[2]), fmt(res$rmse[3]),
fmt(res$rmse[4]), fmt_or_dash(res$rmse[5])))
}
cat("\\hline\n")
}
cat("\\end{tabular}}\n\n")
cat("\\vspace{0.3cm}\n\\begin{minipage}{\\textwidth}\n\\footnotesize\n")
cat("\\textit{Notes:} Bias and RMSE of the W-ARMA-SV estimator for SV(2) models with standardized GED innovations. The SV(2) DGPs use $\\phi_1 = 0.20$ with $\\phi_2$ chosen so that the largest AR root matches the SV(1) persistence in Table~\\ref{tab:ged} (root $= 0.90$ for medium, $0.95$ for high persistence). Bias and RMSE for $\\phi_1$, $\\phi_2$, $\\sigma_y$, and $\\sigma_v$ are computed over all $B$ replications; $\\nu$ statistics are reported only for interior solutions. Based on $B = ", B, "$ Monte Carlo replications with $J = ", J, "$ and $\\delta = ", del, "$. $T$ = sample size.\n", sep = "")
cat("\\end{minipage}\n\\end{table}\n")
sink()
cat("  -> tableA2.tex written\n\n")
cat("=== Done ===\n")
devtools::document()
