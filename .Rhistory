dgp$phi[1], dgp$phi[2], dgp$sigy, dgp$sigv, dgp$nu))
for (i in seq_along(Tsize_ls)) {
Tsize <- Tsize_ls[i]
res <- find_resA1(dgp, Tsize)
cat(sprintf(" & %d & %s & %s & %s & %s & %s & & %s & %s & %s & %s & %s \\\\\n",
Tsize,
fmt(res$bias[1]), fmt(res$bias[2]), fmt(res$bias[3]),
fmt(res$bias[4]), fmt_or_dash(res$bias[5]),
fmt(res$rmse[1]), fmt(res$rmse[2]), fmt(res$rmse[3]),
fmt(res$rmse[4]), fmt_or_dash(res$rmse[5])))
}
cat("\\hline\n")
}
cat("\\end{tabular}}\n\n")
cat("\\vspace{0.3cm}\n\\begin{minipage}{\\textwidth}\n\\footnotesize\n")
cat("\\textit{Notes:} Bias and RMSE of the W-ARMA-SV estimator for SV(2) models with standardized Student-$t$ innovations, $z_t \\sim t_\\nu/\\sqrt{\\nu/(\\nu-2)}$. The SV(2) DGPs use $\\phi_1 = 0.20$ with $\\phi_2$ chosen so that the largest AR root matches the SV(1) persistence in Table~\\ref{tab:student_t} (root $= 0.90$ for medium, $0.95$ for high persistence). Bias and RMSE for $\\phi_1$, $\\phi_2$, $\\sigma_y$, and $\\sigma_v$ are computed over all $B$ replications; $\\nu$ statistics are reported only for interior solutions. Based on $B = ", B, "$ Monte Carlo replications with $J = ", J, "$ and $\\delta = ", del, "$. $T$ = sample size.\n", sep = "")
cat("\\end{minipage}\n\\end{table}\n")
sink()
cat("  -> tableA1.tex written\n\n")
# ============================================================================ #
# TABLE A2: GED SV(2)                                                      ----
# ============================================================================ #
cat("====== TABLE A2: GED SV(2) ======\n")
dgp_tabA2 <- list(
list(phi = c(0.20, phi2_medium), sigy = 1.0, sigv = 1.0, nu = 1.5,
persist = "Medium"),
list(phi = c(0.20, phi2_high),   sigy = 1.0, sigv = 1.0, nu = 1.5,
persist = "High"),
list(phi = c(0.20, phi2_medium), sigy = 1.0, sigv = 1.0, nu = 1.0,
persist = "Medium"),
list(phi = c(0.20, phi2_high),   sigy = 1.0, sigv = 1.0, nu = 1.0,
persist = "High")
)
results_tabA2 <- list()
for (dgp in dgp_tabA2) {
true_theta <- c(dgp$phi, dgp$sigy, dgp$sigv, dgp$nu)
n_par <- 5
for (Tsize in Tsize_ls) {
cat(sprintf("  GED SV(2) nu=%.1f, %s pers., T=%d\n",
dgp$nu, dgp$persist, Tsize))
estimsB <- matrix(NA, B, n_par)
xb <- 1
while (xb <= B) {
y <- sim_svp(Tsize, phi = dgp$phi, sigy = dgp$sigy,
sigv = dgp$sigv, errorType = "GED",
nu = dgp$nu, burnin = burnin)
mdl <- tryCatch(
suppressWarnings(svp(y, p = 2, J = J, leverage = FALSE,
errorType = "GED", del = del,
wDecay = wDecay)),
error = function(e) NULL
)
if (!is.null(mdl)) {
estimsB[xb, ] <- c(mdl$phi, mdl$sigy, mdl$sigv, mdl$v)
xb <- xb + 1
}
}
bias_all <- colMeans(estimsB) - true_theta
rmse_all <- sqrt(colMeans((estimsB - matrix(true_theta, B, n_par,
byrow = TRUE))^2))
interior <- !is_boundary_ged(estimsB[, n_par])
bd_rate <- 1 - mean(interior)
if (sum(interior) > 0) {
bias_all[n_par] <- mean(estimsB[interior, n_par]) - dgp$nu
rmse_all[n_par] <- sqrt(mean((estimsB[interior, n_par] - dgp$nu)^2))
} else {
bias_all[n_par] <- NA; rmse_all[n_par] <- NA
}
cat(sprintf("    boundary rate: %.1f%%\n", 100 * bd_rate))
results_tabA2[[length(results_tabA2) + 1]] <- list(
dgp = dgp, Tsize = Tsize, bias = bias_all, rmse = rmse_all, bd_rate = bd_rate)
}
}
# Write tableA2.tex
find_resA2 <- function(dgp, Tsize) {
for (r in results_tabA2) {
if (all(r$dgp$phi == dgp$phi) && r$dgp$nu == dgp$nu &&
r$Tsize == Tsize)
return(r)
}
NULL
}
sink(file.path(paper_dir, "tables/tableA2.tex"))
cat("\\begin{table}[!t]\n\\centering\n")
cat("\\caption{Monte Carlo estimation results: GED SV(2) models.}\n")
cat("\\label{tab:ged_sv2}\n\\small\n")
cat("\\vspace{0.3cm}\n\n")
cat("\\adjustbox{max width=\\textwidth}{%\n")
cat("\\begin{tabular}{l l rrrrr c rrrrr}\n\\hline\\hline\n")
cat(" & & \\multicolumn{5}{c}{Bias} & & \\multicolumn{5}{c}{RMSE} \\\\\n")
cat("\\cline{3-7} \\cline{9-13}\n")
cat("DGP & $T$ & $\\phi_1$ & $\\phi_2$ & $\\sigma_y$ & $\\sigma_v$ & $\\nu$ & & $\\phi_1$ & $\\phi_2$ & $\\sigma_y$ & $\\sigma_v$ & $\\nu$ \\\\\n\\hline\n")
for (dgp in dgp_tabA2) {
nu_label <- if (dgp$nu == 1.0) "Laplace" else "Heavy tails"
cat(sprintf("\\multirow{4}{*}{\\makecell[l]{$\\nu\\!=\\!%.1f$ (%s),\\\\\\ %s pers.\\\\\\ \\footnotesize True: $\\phi_1\\!=\\!%.2f,\\; \\phi_2\\!=\\!%.2f,$\\\\\\ \\footnotesize $\\sigma_y\\!=\\!%.1f,\\; \\sigma_v\\!=\\!%.1f,\\; \\nu\\!=\\!%.1f$}}",
dgp$nu, nu_label, dgp$persist,
dgp$phi[1], dgp$phi[2], dgp$sigy, dgp$sigv, dgp$nu))
for (i in seq_along(Tsize_ls)) {
Tsize <- Tsize_ls[i]
res <- find_resA2(dgp, Tsize)
cat(sprintf(" & %d & %s & %s & %s & %s & %s & & %s & %s & %s & %s & %s \\\\\n",
Tsize,
fmt(res$bias[1]), fmt(res$bias[2]), fmt(res$bias[3]),
fmt(res$bias[4]), fmt_or_dash(res$bias[5]),
fmt(res$rmse[1]), fmt(res$rmse[2]), fmt(res$rmse[3]),
fmt(res$rmse[4]), fmt_or_dash(res$rmse[5])))
}
cat("\\hline\n")
}
cat("\\end{tabular}}\n\n")
cat("\\vspace{0.3cm}\n\\begin{minipage}{\\textwidth}\n\\footnotesize\n")
cat("\\textit{Notes:} Bias and RMSE of the W-ARMA-SV estimator for SV(2) models with standardized GED innovations. The SV(2) DGPs use $\\phi_1 = 0.20$ with $\\phi_2$ chosen so that the largest AR root matches the SV(1) persistence in Table~\\ref{tab:ged} (root $= 0.90$ for medium, $0.95$ for high persistence). Bias and RMSE for $\\phi_1$, $\\phi_2$, $\\sigma_y$, and $\\sigma_v$ are computed over all $B$ replications; $\\nu$ statistics are reported only for interior solutions. Based on $B = ", B, "$ Monte Carlo replications with $J = ", J, "$ and $\\delta = ", del, "$. $T$ = sample size.\n", sep = "")
cat("\\end{minipage}\n\\end{table}\n")
sink()
cat("  -> tableA2.tex written\n\n")
cat("=== Done ===\n")
devtools::document()
## ============================================================================ #
##
##  HYPOTHESIS TESTING MONTE CARLO STUDY
##  wARMASVp R Package Paper — Ahsan, Dufour & Rodriguez Rondon (2026)
##
##  This script evaluates the finite-sample size and power of three testing
##  procedures: Asymptotic (chi-squared), Local Monte Carlo (LMC), and
##  Maximized Monte Carlo (MMC).
##
##  Three types of tests are evaluated:
##    Section 1: AR order testing (SV(1) vs SV(2))
##    Section 2: Leverage testing (H0: rho = 0)
##    Section 3: Distribution testing (normality vs heavy tails)
##
##  Outputs:
##    - paper/tables/testing_mc_results.RData   (raw results)
##    - paper/figures/testing_*.pdf              (rejection rate plots)
##    - paper/tables/testing_*.tex               (LaTeX tables)
##
##  To run: source("run_testing_mc.R")  OR  Rscript run_testing_mc.R
##
## ============================================================================ #
# ============================================================
# USER SETTINGS — Change these before running
# (If already set in the environment, those values are kept)
# ============================================================
if (!exists("n_workers")) n_workers <- 10        # Parallel workers (1 = sequential)
if (!exists("B"))         B         <- 1000     # MC replications (outer loop)
if (!exists("N_mc"))      N_mc      <- 99       # MC reps inside each LMC/MMC test
if (!exists("seed"))      seed      <- 535725   # Random seed
if (!exists("paper_dir")) paper_dir <- "~/Dropbox/Res/papers/SVp_Rpack/paper"
if (!exists("run_mmc"))   run_mmc   <- TRUE     # Set FALSE to skip MMC (faster)
if (!exists("B_mmc"))     B_mmc     <- 200      # MMC outer reps (expensive)
if (!exists("maxit_mmc")) maxit_mmc <- 50       # MMC optimizer iterations
# ============================================================
rm(list = setdiff(ls(), c("n_workers", "B", "N_mc", "seed", "paper_dir",
"run_mmc", "B_mmc", "maxit_mmc")))
library(wARMASVp)
library(ggplot2)
dir.create(file.path(paper_dir, "tables"), showWarnings = FALSE)
dir.create(file.path(paper_dir, "figures"), showWarnings = FALSE)
# Fixed settings
J      <- 100
del    <- 1e-6
burnin <- 500
wDecay <- FALSE
alpha  <- 0.05
chi2_crit <- qchisq(1 - alpha, df = 1)
Tsize_ls <- c(1000, 2000, 5000)
cat("============================================================\n")
cat("  HYPOTHESIS TESTING MONTE CARLO STUDY\n")
cat("============================================================\n")
cat(sprintf("  B = %d (LMC), B_mmc = %d (MMC)\n", B, B_mmc))
cat(sprintf("  N_mc = %d, J = %d, alpha = %.2f\n", N_mc, J, alpha))
cat(sprintf("  Workers = %d, Seed = %d\n", n_workers, seed))
cat(sprintf("  Run MMC: %s\n", run_mmc))
cat("============================================================\n\n")
# ============================================================================ #
# Helper: Run one replication of the testing MC
# ============================================================================ #
# This function runs one replication: simulate data, run the test, return result
# Returns: list(asy_reject, lmc_reject, mmc_reject)
run_one_test_rep <- function(b, dgp, Tsize, test_type, test_params,
J, del, burnin, wDecay, N_mc, alpha, chi2_crit,
run_mmc, maxit_mmc) {
result <- list(asy = NA, lmc = NA, mmc = NA)
# --- Simulate data ---
y <- tryCatch({
if (test_type == "ar_order") {
# Gaussian, no leverage
sim_svp(Tsize, phi = dgp$phi, sigy = dgp$sigy, sigv = dgp$sigv,
burnin = burnin)
} else if (test_type == "leverage") {
out <- sim_svp(Tsize, phi = dgp$phi, sigy = dgp$sigy, sigv = dgp$sigv,
errorType = dgp$errorType,
leverage = (dgp$rho != 0), rho = dgp$rho,
nu = dgp$nu, burnin = burnin)
if (is.list(out)) out$y else out
} else if (test_type == "distribution") {
sim_svp(Tsize, phi = dgp$phi, sigy = dgp$sigy, sigv = dgp$sigv,
errorType = dgp$errorType, nu = dgp$nu, burnin = burnin)
}
}, error = function(e) NULL)
if (is.null(y)) return(result)
y <- as.numeric(y)
# --- Run tests based on test_type ---
if (test_type == "ar_order") {
# LMC for AR order
lmc_out <- tryCatch(
suppressWarnings(
lmc_ar(y, p_null = test_params$p_null, p_alt = test_params$p_alt,
J = J, N = N_mc, burnin = burnin, del = del, wDecay = wDecay)),
error = function(e) NULL)
if (!is.null(lmc_out)) result$lmc <- (lmc_out$pval < alpha)
# MMC for AR order
if (run_mmc) {
mmc_out <- tryCatch(
suppressWarnings(
mmc_ar(y, p_null = test_params$p_null, p_alt = test_params$p_alt,
J = J, N = N_mc, burnin = burnin, del = del, wDecay = wDecay,
method = "pso", maxit = maxit_mmc)),
error = function(e) NULL)
if (!is.null(mmc_out)) result$mmc <- (mmc_out$value < alpha)
}
} else if (test_type == "leverage") {
# LMC for leverage
lmc_out <- tryCatch(
suppressWarnings(
lmc_lev(y, p = length(dgp$phi), J = J, N = N_mc, rho_null = 0,
errorType = dgp$errorType, del = del, burnin = burnin,
Bartlett = FALSE)),
error = function(e) NULL)
if (!is.null(lmc_out)) {
result$lmc <- (lmc_out$pval < alpha)
result$asy_stat <- lmc_out$s0  # Use same stat for asymptotic
}
# Asymptotic: compare s0 to chi^2_1 critical value
if (!is.null(lmc_out)) {
# Re-compute with HAC for asymptotic version
fit_alt <- tryCatch(
suppressWarnings(svp(y, p = length(dgp$phi), J = J, leverage = TRUE,
errorType = dgp$errorType, del = del)),
error = function(e) NULL)
if (!is.null(fit_alt) && !is.na(fit_alt$rho)) {
fit_null <- fit_alt; fit_null$rho <- 0
y_mat <- as.matrix(y)
p_len <- length(dgp$phi)
if (dgp$errorType == "Gaussian") {
s_asy <- tryCatch(
Tsize * (LRT_moment_lev_svp_Amat(y_mat, fit_null, "pearson", del, TRUE) -
LRT_moment_lev_svp_Amat(y_mat, fit_alt, "pearson", del, TRUE)),
error = function(e) NA)
} else if (dgp$errorType == "Student-t") {
s_asy <- tryCatch(
Tsize * (LRT_moment_lev_t_Amat(y_mat, fit_null, "pearson", del, TRUE) -
LRT_moment_lev_t_Amat(y_mat, fit_alt, "pearson", del, TRUE)),
error = function(e) NA)
} else {
s_asy <- tryCatch(
Tsize * (LRT_moment_lev_ged_Amat(y_mat, fit_null, "pearson", del, TRUE) -
LRT_moment_lev_ged_Amat(y_mat, fit_alt, "pearson", del, TRUE)),
error = function(e) NA)
}
if (!is.na(s_asy) && s_asy >= 0) result$asy <- (s_asy > chi2_crit)
}
}
# MMC for leverage
if (run_mmc) {
mmc_out <- tryCatch(
suppressWarnings(
mmc_lev(y, p = length(dgp$phi), J = J, N = N_mc, rho_null = 0,
errorType = dgp$errorType, del = del, burnin = burnin,
Bartlett = FALSE, method = "pso", maxit = maxit_mmc)),
error = function(e) NULL)
if (!is.null(mmc_out)) result$mmc <- (mmc_out$value < alpha)
}
} else if (test_type == "distribution") {
# Distribution testing (Student-t or GED)
if (dgp$errorType == "Student-t") {
lmc_out <- tryCatch(
suppressWarnings(
lmc_t(y, p = 1, J = J, N = N_mc, nu_null = test_params$nu_null,
del = del, burnin = burnin)),
error = function(e) NULL)
if (!is.null(lmc_out)) result$lmc <- (lmc_out$pval < alpha)
if (run_mmc) {
mmc_out <- tryCatch(
suppressWarnings(
mmc_t(y, p = 1, J = J, N = N_mc, nu_null = test_params$nu_null,
del = del, burnin = burnin, method = "pso", maxit = maxit_mmc)),
error = function(e) NULL)
if (!is.null(mmc_out)) result$mmc <- (mmc_out$value < alpha)
}
} else if (dgp$errorType == "GED") {
lmc_out <- tryCatch(
suppressWarnings(
lmc_ged(y, p = 1, J = J, N = N_mc, nu_null = test_params$nu_null,
del = del, burnin = burnin)),
error = function(e) NULL)
if (!is.null(lmc_out)) result$lmc <- (lmc_out$pval < alpha)
if (run_mmc) {
mmc_out <- tryCatch(
suppressWarnings(
mmc_ged(y, p = 1, J = J, N = N_mc, nu_null = test_params$nu_null,
del = del, burnin = burnin, method = "pso", maxit = maxit_mmc)),
error = function(e) NULL)
if (!is.null(mmc_out)) result$mmc <- (mmc_out$value < alpha)
}
}
}
result
}
# ============================================================================ #
# Helper: Run B replications for one test configuration
# ============================================================================ #
run_test_block <- function(dgp, Tsize, test_type, test_params,
B_run, J, del, burnin, wDecay, N_mc,
alpha, chi2_crit, n_workers, block_seed,
run_mmc, maxit_mmc) {
worker_fn <- function(b) {
run_one_test_rep(b, dgp, Tsize, test_type, test_params,
J, del, burnin, wDecay, N_mc, alpha, chi2_crit,
run_mmc, maxit_mmc)
}
if (n_workers > 1) {
RNGkind("L'Ecuyer-CMRG")
set.seed(block_seed)
reps <- parallel::mclapply(seq_len(B_run), worker_fn, mc.cores = n_workers)
} else {
set.seed(block_seed)
reps <- lapply(seq_len(B_run), function(b) {
if (b %% 100 == 0) cat(sprintf("    rep %d/%d\n", b, B_run))
worker_fn(b)
})
}
# Compute rejection rates
asy_vec <- sapply(reps, function(r) r$asy)
lmc_vec <- sapply(reps, function(r) r$lmc)
mmc_vec <- sapply(reps, function(r) r$mmc)
list(
asy_rate = mean(asy_vec, na.rm = TRUE) * 100,
lmc_rate = mean(lmc_vec, na.rm = TRUE) * 100,
mmc_rate = if (run_mmc) mean(mmc_vec, na.rm = TRUE) * 100 else NA,
asy_valid = sum(!is.na(asy_vec)),
lmc_valid = sum(!is.na(lmc_vec)),
mmc_valid = if (run_mmc) sum(!is.na(mmc_vec)) else 0,
B_run = B_run
)
}
# ============================================================================ #
# SECTION 1: AR Order Testing
# ============================================================================ #
cat("====== SECTION 1: AR ORDER TESTING ======\n")
cat("  H0: SV(1) vs H1: SV(2), Gaussian, no leverage\n\n")
ar_results <- list()
ar_idx <- 0L
# Size: true DGP is SV(1) with phi=0.90
dgp_ar_size <- list(phi = 0.90, sigy = 1.0, sigv = 0.50,
errorType = "Gaussian", nu = NULL, rho = 0)
# Power: true DGP is SV(2) with phi=(0.20, 0.63)
dgp_ar_power <- list(phi = c(0.20, 0.63), sigy = 1.0, sigv = 1.0,
errorType = "Gaussian", nu = NULL, rho = 0)
for (dgp_ar in list(list(dgp = dgp_ar_size, type = "SIZE"),
list(dgp = dgp_ar_power, type = "POWER"))) {
for (Tsize in Tsize_ls) {
ar_idx <- ar_idx + 1L
cat(sprintf("  [AR %s] T=%d ...\n", dgp_ar$type, Tsize))
block_seed <- seed + 10000 + ar_idx
res <- run_test_block(dgp_ar$dgp, Tsize, "ar_order",
list(p_null = 1, p_alt = 2),
B, J, del, burnin, wDecay, N_mc,
alpha, chi2_crit, n_workers, block_seed,
run_mmc, maxit_mmc)
res$type <- dgp_ar$type
res$Tsize <- Tsize
ar_results[[ar_idx]] <- res
cat(sprintf("    LMC: %.1f%%  MMC: %s\n",
res$lmc_rate,
if (is.na(res$mmc_rate)) "skipped" else sprintf("%.1f%%", res$mmc_rate)))
}
}
# ============================================================================ #
# SECTION 2: LEVERAGE TESTING
# ============================================================================ #
cat("\n====== SECTION 2: LEVERAGE TESTING ======\n")
cat("  H0: rho = 0, SV(1), all error types\n\n")
lev_results <- list()
lev_idx <- 0L
lev_dgps <- list(
# Size: rho = 0
list(label = "Gaussian SIZE",
phi = 0.90, sigy = 1.0, sigv = 0.50,
errorType = "Gaussian", nu = NULL, rho = 0),
list(label = "Student-t nu=3 SIZE",
phi = 0.90, sigy = 1.0, sigv = 0.50,
errorType = "Student-t", nu = 3, rho = 0),
list(label = "Student-t nu=10 SIZE",
phi = 0.90, sigy = 1.0, sigv = 0.50,
errorType = "Student-t", nu = 10, rho = 0),
list(label = "GED nu=1.0 SIZE",
phi = 0.90, sigy = 1.0, sigv = 0.50,
errorType = "GED", nu = 1.0, rho = 0),
list(label = "GED nu=1.5 SIZE",
phi = 0.90, sigy = 1.0, sigv = 0.50,
errorType = "GED", nu = 1.5, rho = 0),
# Power: rho = -0.5
list(label = "Gaussian POWER",
phi = 0.90, sigy = 1.0, sigv = 0.50,
errorType = "Gaussian", nu = NULL, rho = -0.5),
list(label = "Student-t nu=3 POWER",
phi = 0.90, sigy = 1.0, sigv = 0.50,
errorType = "Student-t", nu = 3, rho = -0.5),
list(label = "Student-t nu=10 POWER",
phi = 0.90, sigy = 1.0, sigv = 0.50,
errorType = "Student-t", nu = 10, rho = -0.5),
list(label = "GED nu=1.0 POWER",
phi = 0.90, sigy = 1.0, sigv = 0.50,
errorType = "GED", nu = 1.0, rho = -0.5),
list(label = "GED nu=1.5 POWER",
phi = 0.90, sigy = 1.0, sigv = 0.50,
errorType = "GED", nu = 1.5, rho = -0.5)
)
for (dgp in lev_dgps) {
for (Tsize in Tsize_ls) {
lev_idx <- lev_idx + 1L
cat(sprintf("  [%s] T=%d ...\n", dgp$label, Tsize))
block_seed <- seed + 20000 + lev_idx
B_run <- if (run_mmc && grepl("POWER", dgp$label)) B_mmc else B
res <- run_test_block(dgp, Tsize, "leverage", list(),
B_run, J, del, burnin, wDecay, N_mc,
alpha, chi2_crit, n_workers, block_seed,
run_mmc, maxit_mmc)
res$label <- dgp$label
res$errorType <- dgp$errorType
res$Tsize <- Tsize
res$rho <- dgp$rho
lev_results[[lev_idx]] <- res
cat(sprintf("    Asy: %.1f%%  LMC: %.1f%%  MMC: %s\n",
res$asy_rate, res$lmc_rate,
if (is.na(res$mmc_rate)) "skipped" else sprintf("%.1f%%", res$mmc_rate)))
}
}
# ============================================================================ #
# SECTION 3: DISTRIBUTION TESTING
# ============================================================================ #
cat("\n====== SECTION 3: DISTRIBUTION TESTING ======\n")
cat("  Normality vs heavy tails, SV(1), no leverage\n\n")
dist_results <- list()
dist_idx <- 0L
dist_dgps <- list(
# Student-t: Size (H0: nu=30, simulate from nu=30)
list(label = "Student-t SIZE (H0:nu=30)",
phi = 0.90, sigy = 1.0, sigv = 0.50,
errorType = "Student-t", nu = 30, rho = 0,
nu_null = 30),
# Student-t: Power (true nu=3, test H0:nu=30)
list(label = "Student-t POWER nu=3",
phi = 0.90, sigy = 1.0, sigv = 0.50,
errorType = "Student-t", nu = 3, rho = 0,
nu_null = 30),
# Student-t: Power (true nu=5, test H0:nu=30)
list(label = "Student-t POWER nu=5",
phi = 0.90, sigy = 1.0, sigv = 0.50,
errorType = "Student-t", nu = 5, rho = 0,
nu_null = 30),
# GED: Size (H0: nu=2, simulate from nu=2)
list(label = "GED SIZE (H0:nu=2)",
phi = 0.90, sigy = 1.0, sigv = 0.50,
errorType = "GED", nu = 2.0, rho = 0,
nu_null = 2),
# GED: Power (true nu=1.0, test H0:nu=2)
list(label = "GED POWER nu=1.0",
phi = 0.90, sigy = 1.0, sigv = 0.50,
errorType = "GED", nu = 1.0, rho = 0,
nu_null = 2),
# GED: Power (true nu=1.5, test H0:nu=2)
list(label = "GED POWER nu=1.5",
phi = 0.90, sigy = 1.0, sigv = 0.50,
errorType = "GED", nu = 1.5, rho = 0,
nu_null = 2)
)
for (dgp in dist_dgps) {
for (Tsize in Tsize_ls) {
dist_idx <- dist_idx + 1L
cat(sprintf("  [%s] T=%d ...\n", dgp$label, Tsize))
block_seed <- seed + 30000 + dist_idx
res <- run_test_block(dgp, Tsize, "distribution",
list(nu_null = dgp$nu_null),
B, J, del, burnin, wDecay, N_mc,
alpha, chi2_crit, n_workers, block_seed,
run_mmc, maxit_mmc)
res$label <- dgp$label
res$errorType <- dgp$errorType
res$Tsize <- Tsize
dist_results[[dist_idx]] <- res
cat(sprintf("    LMC: %.1f%%  MMC: %s\n",
res$lmc_rate,
if (is.na(res$mmc_rate)) "skipped" else sprintf("%.1f%%", res$mmc_rate)))
}
}
# ============================================================================ #
# Save all results
# ============================================================================ #
results_file <- file.path(paper_dir, "tables", "testing_mc_results.RData")
save(ar_results, lev_results, dist_results,
B, B_mmc, N_mc, alpha, seed, Tsize_ls,
file = results_file)
cat(sprintf("\nResults saved to: %s\n", results_file))
cat("\n============================================================\n")
cat("  TESTING MC STUDY COMPLETE\n")
cat(sprintf("  Date: %s\n", date()))
cat("============================================================\n")
library(wARMASVp)
library(wARMASVp)
library(wARMASVp)
