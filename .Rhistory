}
NULL
}
find_res3b <- function(dgp, Tsize) {
for (r in results_tab3b) {
if (all(r$dgp$phi == dgp$phi) && r$dgp$nu == dgp$nu && r$Tsize == Tsize)
return(r)
}
NULL
}
