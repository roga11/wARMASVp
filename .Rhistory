# ============================================================================ #
# TABLE 4: GED SV(1) and SV(2) — No Leverage                             ----
# ============================================================================ #
cat("====== TABLE 4: GED SV(1) and SV(2) ======\n")
# Panel A: SV(1)
dgp_tab4a <- list(
list(phi = 0.90, sigy = 1.0, sigv = 1.5, nu = 1.5, persist = "Medium"),
list(phi = 0.95, sigy = 1.0, sigv = 1.5, nu = 1.5, persist = "High"),
list(phi = 0.90, sigy = 1.0, sigv = 1.5, nu = 1.0, persist = "Medium"),
list(phi = 0.95, sigy = 1.0, sigv = 1.5, nu = 1.0, persist = "High")
)
results_tab4a <- list()
for (dgp in dgp_tab4a) {
true_theta <- c(dgp$phi, dgp$sigy, dgp$sigv, dgp$nu)
n_par <- 4
for (Tsize in Tsize_ls) {
cat(sprintf("  GED SV(1) nu=%.1f, %s pers., T=%d\n", dgp$nu, dgp$persist, Tsize))
estimsB <- matrix(NA, B, n_par)
xb <- 1
while (xb <= B) {
y <- sim_svp(Tsize, phi = dgp$phi, sigy = dgp$sigy,
sigv = dgp$sigv, errorType = "GED",
nu = dgp$nu, burnin = burnin)
mdl <- tryCatch(
svp(y, p = 1, J = J, leverage = FALSE, errorType = "GED",
del = del, wDecay = wDecay),
error = function(e) NULL
)
if (!is.null(mdl) && all(!is.na(mdl$theta))) {
estimsB[xb, ] <- c(mdl$phi, mdl$sigy, mdl$sigv, mdl$v)
xb <- xb + 1
}
}
bias <- colMeans(estimsB) - true_theta
rmse <- sqrt(colMeans((estimsB - matrix(true_theta, B, n_par, byrow = TRUE))^2))
results_tab4a[[length(results_tab4a) + 1]] <- list(
dgp = dgp, Tsize = Tsize, bias = bias, rmse = rmse)
}
}
# Panel B: SV(2)
dgp_tab4b <- list(
list(phi = c(0.05, 0.70), sigy = 1.0, sigv = 1.0, nu = 1.5, persist = "Medium"),
list(phi = c(0.05, 0.85), sigy = 1.0, sigv = 1.0, nu = 1.5, persist = "High"),
list(phi = c(0.05, 0.70), sigy = 1.0, sigv = 1.0, nu = 1.0, persist = "Medium"),
list(phi = c(0.05, 0.85), sigy = 1.0, sigv = 1.0, nu = 1.0, persist = "High")
)
results_tab4b <- list()
for (dgp in dgp_tab4b) {
true_theta <- c(dgp$phi, dgp$sigy, dgp$sigv, dgp$nu)
n_par <- 5
for (Tsize in Tsize_ls) {
cat(sprintf("  GED SV(2) nu=%.1f, %s pers., T=%d\n", dgp$nu, dgp$persist, Tsize))
estimsB <- matrix(NA, B, n_par)
xb <- 1
while (xb <= B) {
y <- sim_svp(Tsize, phi = dgp$phi, sigy = dgp$sigy,
sigv = dgp$sigv, errorType = "GED",
nu = dgp$nu, burnin = burnin)
mdl <- tryCatch(
suppressWarnings(svp(y, p = 2, J = J, leverage = FALSE,
errorType = "GED", del = del, wDecay = wDecay)),
error = function(e) NULL
)
if (!is.null(mdl) && all(!is.na(mdl$theta))) {
estimsB[xb, ] <- c(mdl$phi, mdl$sigy, mdl$sigv, mdl$v)
xb <- xb + 1
}
}
bias <- colMeans(estimsB) - true_theta
rmse <- sqrt(colMeans((estimsB - matrix(true_theta, B, n_par, byrow = TRUE))^2))
results_tab4b[[length(results_tab4b) + 1]] <- list(
dgp = dgp, Tsize = Tsize, bias = bias, rmse = rmse)
}
}
# Write table4.tex
find_res4a <- function(dgp, Tsize) {
for (r in results_tab4a) {
if (r$dgp$phi == dgp$phi && r$dgp$nu == dgp$nu && r$Tsize == Tsize)
return(r)
}
NULL
}
find_res4b <- function(dgp, Tsize) {
for (r in results_tab4b) {
if (all(r$dgp$phi == dgp$phi) && r$dgp$nu == dgp$nu && r$Tsize == Tsize)
return(r)
}
NULL
}
