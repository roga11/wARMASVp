cat(sprintf("\\multirow{4}{*}{\\makecell[l]{$\\nu\\!=\\!%.1f$ (%s),\\\\\\ %s pers.\\\\\\ \\footnotesize True: $\\phi\\!=\\!%.2f,\\; \\sigma_y\\!=\\!%.1f,$\\\\\\ \\footnotesize $\\sigma_v\\!=\\!%.1f,\\; \\nu\\!=\\!%.1f$}}", dgp$nu, nu_label, dgp$persist, dgp$phi, dgp$sigy, dgp$sigv, dgp$nu))
